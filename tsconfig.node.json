{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Node.js Backend Configuration",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    // Modern Node module resolution (replaces deprecated "node10"/"Node").
    // We keep the OUTPUT as CommonJS because nothing in this monorepo
    // declares `"type": "module"` in package.json — meaning every file
    // is treated as CJS by Node, even under node16 type-checking.
    //
    // Two consequences:
    //   - Dynamic `await import('./relative')` calls don't need explicit
    //     .js extensions (CJS interop)
    //   - ESM-only deps (yjs, @google/genai) must use dynamic import()
    //     instead of static `import` because static CJS→ESM is rejected
    "module": "Node16",
    "moduleResolution": "node16",
    "target": "ES2022",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node"]
  }
}
