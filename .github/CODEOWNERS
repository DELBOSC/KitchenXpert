/packages/api-client/ @kitchenxpert/backend-team
/packages/common/ @kitchenxpert/backend-team @kitchenxpert/frontend-team

# 3D Engine
/packages/3d-engine/ @kitchenxpert/3d-team

# Catalog Providers
