# =================================
# KITCHENXPERT - ENVIRONMENT CONFIG
# =================================
#
# OPTION 1 (recommande) : Utiliser Infisical
#   infisical login
#   infisical run -- pnpm dev
#   Voir docs/infisical-setup.md pour le guide complet
#
# OPTION 2 : Copier ce fichier en .env et remplir les valeurs
#   cp .env.example .env
#
# Variables marked with [REQUIRED] must be set for the application to start
# Variables marked with [RECOMMENDED] should be set for production use
#
# /!\ SECRETS : toutes les valeurs ci-dessous sont des PLACEHOLDERS BIDON.
#     Ne jamais commiter de vraie valeur. Le .env reel est gitignore.

# =================================
# DATABASE [REQUIRED]
# =================================
DATABASE_URL=postgresql://user:password@localhost:5432/kitchenxpert

# Individual DB settings -- requis EN PROD (pool pg natif, hors validateur zod ;
# leur absence fait echouer le boot car les defauts pointent sur localhost)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kitchenxpert
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_SSL=false

# =================================
# REDIS [REQUIRED for production]
# =================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# =================================
# JWT [REQUIRED]
# Secrets must be at least 32 characters
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# =================================
JWT_ACCESS_SECRET=your-super-secure-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-super-secure-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# =================================
# SERVER [REQUIRED]
# =================================
NODE_ENV=development
PORT=4000
API_HOST=localhost
HOST=localhost
APP_NAME=KitchenXpert
APP_URL=http://localhost:3001
API_URL=http://localhost:4000
# Ajouts prod (lus par le code, absents de l'ancien template)
APP_VERSION=1.0.0
API_PORT=4000
FRONTEND_URL=http://localhost:3001
SITE_URL=http://localhost:3001
# Reverse proxy : nb de hops de confiance (Express trust proxy). Requis en prod
# derriere un load balancer pour que secure cookies + rate-limit voient la vraie IP.
TRUST_PROXY=false

# =================================
# CORS [REQUIRED]
# =================================
# CORS_ORIGINS (plural, comma-separated) is the primary variable used by the CORS middleware.
# CORS_ORIGIN (singular) is a legacy fallback used only if CORS_ORIGINS is not set.
CORS_ORIGINS=http://localhost:3001,http://localhost:3002
CORS_ORIGIN=http://localhost:3001
# Ajouts prod
CORS_CREDENTIALS=true
CORS_MAX_AGE=86400

# =================================
# EMAIL [RECOMMENDED]
# =================================
# Provider: 'console' (development), 'smtp', or 'sendgrid'
MAIL_PROVIDER=console
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# SMTP_PASSWORD : alias/fallback de SMTP_PASS (le code lit les deux, SMTP_PASS prioritaire)
SMTP_PASSWORD=
MAIL_FROM=noreply@kitchenxpert.com
EMAIL_FROM=noreply@kitchenxpert.com

# SendGrid (alternative to SMTP)
SENDGRID_API_KEY=

# =================================
# MONITORING / OBSERVABILITE [RECOMMENDED]
# =================================
SENTRY_DSN=
LOG_LEVEL=info
# Ajouts prod
LOG_FILE_PATH=logs/app.log
# OpenTelemetry (traces/metrics). Laisser vide pour desactiver l'export.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=kitchenxpert-backend

# =================================
# SECURITY [RECOMMENDED]
# =================================
DATA_ENCRYPTION_KEY=your-encryption-key-change-in-production
BCRYPT_ROUNDS=10
ENABLE_RATE_LIMIT=true
ENABLE_HELMET=true
ENABLE_CORS=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
# Ajouts prod
# Cle d'authentification des endpoints internes (machine-to-machine). Secret.
INTERNAL_API_KEY=changeme-internal-api-key
# Origines autorisees pour le portail partenaire (comma-separated)
PARTNER_ALLOWED_ORIGINS=http://localhost:3001

# =================================
# SEED (donnees de demo) [OPTIONAL]
# =================================
# Mot de passe des comptes de demo crees par le seed runner. Secret -- ne pas
# exposer en prod ; laisser vide desactive la creation de comptes de demo.
SEED_USER_PASSWORD=changeme-seed-password

# =================================
# JOBS PLANIFIES (GDPR purge, sync providers) [OPTIONAL]
# =================================
# Tous OFF par defaut. DRY_RUN=true journalise sans ecrire.
GDPR_PURGE_ENABLED=false
GDPR_PURGE_DRY_RUN=true
GDPR_PURGE_INTERVAL_MS=86400000
GDPR_PURGE_RETENTION_MS=63072000000
PROVIDER_SYNC_ENABLED=false
PROVIDER_SYNC_DRY_RUN=true
PROVIDER_SYNC_INTERVAL_MS=86400000
PROVIDER_SYNC_PROVIDERS=
# Pont vers le package scraper (ingestion catalogue). OFF par defaut.
SCRAPER_BRIDGE_ENABLED=false

# =================================
# FEATURE FLAGS [OPTIONAL]
# =================================
FEATURE_AI_ENABLED=true
FEATURE_3D_ENABLED=true
FEATURE_PARTNERS_ENABLED=true

# =================================
# EXTERNAL APIS [OPTIONAL]
# =================================
# Payment - Stripe
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
# [PROD] Shared secret for INBOUND webhooks (verifyWebhook). Server-side only —
# NEVER sent in a request header. Without it, verifyWebhook refuses to mount (fail-closed).
WEBHOOK_SECRET=change-me-inbound-webhook-hmac-secret
STRIPE_WEBHOOK_SECRET=

# AI Services
OPENAI_API_KEY=
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Google Gemini (used for photorealistic kitchen image generation)
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_GENAI_API_KEY=your_google_genai_api_key_here
AI_MODULES_ENDPOINT=http://localhost:5000

# =================================
# AWS S3 (File Storage) [OPTIONAL]
# =================================
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=kitchenxpert-uploads

# =================================
# NON-PROD (scraper / frontend Vite / tests-CI)
# =================================
# Ces variables ne concernent PAS le runtime backend de prod :
#  - Package scraper   : PROXY_ENABLED/PROXY_LIST/PROXY_ROTATION_ENABLED,
#                        SCRAPE_MAX_CONCURRENT/SCRAPE_RATE_LIMIT_MS/SCRAPE_RETRY_ATTEMPTS,
#                        SCRAPER_API_KEY
#  - Frontend (Vite)   : VITE_API_URL, VITE_SOURCEMAP  (vivent dans packages/frontend/)
#  - Tests / CI        : E2E_API_URL, E2E_BASE_URL, PLAYWRIGHT_SUITE, SMOKE_TIMEOUT_MS,
#                        DEBUG_SCREENSHOTS, DEBUG_SCREENSHOTS_PATH, ANALYZE, CI
# Elles sont documentees ici pour reference mais se configurent dans leur package.

# =================================
# ANALYTICS [OPTIONAL]
# =================================
# [LEGACY / mort -- 0 reference dans le code, cleanup trace dans CLAUDE.md, NON retire ici]
GOOGLE_ANALYTICS_ID=
MIXPANEL_TOKEN=

# =================================
# CATALOG PROVIDERS [OPTIONAL]
# =================================
# [LEGACY / mort -- scaffolding catalog-providers/ par-marque abandonne (cf CLAUDE.md
#  sec 15.2). 0 reference active. Cleanup trace, NON retire ici.]
IKEA_API_ENDPOINT=https://api.ikea.com/v1
IKEA_API_KEY=
IKEA_AUTH_SECRET=
LEROY_MERLIN_API_ENDPOINT=https://api.leroymerlin.fr/v1
LEROY_MERLIN_API_KEY=
CASTORAMA_API_ENDPOINT=https://api.castorama.fr/v1
CASTORAMA_API_KEY=
BOSCH_API_ENDPOINT=https://api.bosch-home.com/v1
BOSCH_API_KEY=


# =================================
# 3D ENGINE [OPTIONAL]
# =================================
# [LEGACY / mort -- 0 reference active. Cleanup trace, NON retire ici.]
THREEJS_CDN=https://cdn.jsdelivr.net/npm/three@latest
