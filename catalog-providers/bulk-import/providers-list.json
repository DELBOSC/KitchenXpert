  "description": "Liste des providers avec APIs publiques disponibles pour import automatique",
  "providers": [
    {
      "id": "ikea-api",
      "name": "IKEA Retail API",
      "baseUrl": "https://api.ikea.com/v1",
      "endpoints": {
        "products": "/products",
        "categories": "/categories"
      },
      "rateLimit": {
        "requestsPerSecond": 5,
        "maxConcurrent": 2
      },
      "pagination": {
        "type": "offset",
        "limitParam": "limit",
        "offsetParam": "offset",
        "maxLimit": 100
      },
      "authentication": {
        "type": "apiKey",
        "header": "X-API-Key"
      },
      "mapping": {
        "templateId": "ikea"
      },
      "status": "active",
      "coverage": ["furniture", "appliance"],
      "notes": "Nécessite une clé API IKEA Developer Portal"
    },
