  "statusDefinitions": {
    "active": "API officielle, stable et recommandée",
    "experimental": "API en développement, peut changer",
    "limited": "API avec restrictions importantes",
    "community": "API communautaire non-officielle",
    "deprecated": "API obsolète, à ne plus utiliser"
  },
  "notes": [
    "⚠️  Les APIs marquées 'experimental' ou 'community' peuvent ne pas fonctionner",
    "🔑 La plupart des APIs nécessitent une clé API (à configurer dans .env)",
    "📊 Les rate limits doivent être respectés pour éviter les bans",
    "⚖️  Vérifier les conditions d'utilisation de chaque API",
    "🔄 Liste mise à jour régulièrement, check for updates"
  ],
