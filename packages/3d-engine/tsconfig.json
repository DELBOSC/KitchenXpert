{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "@kitchenxpert/3d-engine",
  "extends": "../../tsconfig.lib.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    // baseUrl removed (deprecated). Path values now embed `./src/`.
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@/*": ["./src/*"],
      "@/api/*": ["./src/api/*"],
      "@/engine/*": ["./src/engine/*"],
      "@/models/*": ["./src/models/*"],
      "@/utils/*": ["./src/utils/*"],
      "@kitchenxpert/common": ["../common/src"],
      "@kitchenxpert/common/*": ["../common/src/*"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.spec.ts",
    "src/test/**/*"
  ],
  "references": [{ "path": "../common" }]
}
