---
/**
 * Hub `/guides/` — landing page for all editorial content.
 *
 * Lists every published article grouped by collection. Server-side
 * search isn't needed at 50 articles; we render the full grid + a
 * client-side filter (vanilla JS, ~30 lines).
 */
import { getCollection, type CollectionEntry } from 'astro:content';

type AnyEntry =
  | CollectionEntry<'layouts'>
  | CollectionEntry<'cuisinistes'>
  | CollectionEntry<'budgets'>
  | CollectionEntry<'styles'>
  | CollectionEntry<'comparatifs'>
  | CollectionEntry<'pratiques'>;

const COLLECTION_PATH: Record<string, string> = {
  layouts: 'guides',
  pratiques: 'guides',
  cuisinistes: 'cuisinistes',
  budgets: 'budget',
  styles: 'styles',
  comparatifs: 'comparatifs',
};

const COLLECTION_LABEL: Record<string, string> = {
  layouts: 'Layouts',
  cuisinistes: 'Cuisinistes',
  budgets: 'Budgets',
  styles: 'Styles',
  comparatifs: 'Comparatifs',
  pratiques: 'Guides pratiques',
};

const all = (
  await Promise.all([
    getCollection('layouts',     ({ data }) => !data.draft),
    getCollection('cuisinistes', ({ data }) => !data.draft),
    getCollection('budgets',     ({ data }) => !data.draft),
    getCollection('styles',      ({ data }) => !data.draft),
    getCollection('comparatifs', ({ data }) => !data.draft),
    getCollection('pratiques',   ({ data }) => !data.draft),
  ])
).flat() as AnyEntry[];

// Group by collection for the rendered grid.
const grouped: Record<string, AnyEntry[]> = {};
for (const entry of all) {
  (grouped[entry.collection] ||= []).push(entry);
}
const collectionOrder = ['layouts', 'cuisinistes', 'budgets', 'styles', 'comparatifs', 'pratiques'] as const;

const SITE = 'https://kitchenxpert.com';
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Guides cuisine — KitchenXpert</title>
    <meta name="description" content="Tout pour concevoir votre cuisine : layouts, comparatifs cuisinistes, budgets, styles. 50+ guides écrits par des architectes et cuisinistes." />
    <link rel="canonical" href={`${SITE}/guides`} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Guides cuisine — KitchenXpert" />
    <meta property="og:description" content="50+ guides indépendants pour concevoir votre cuisine : layouts, cuisinistes, budgets, styles." />
    <meta property="og:url" content={`${SITE}/guides`} />
    <meta property="og:image" content={`${SITE}/og/default.svg`} />
    <link rel="preload" href="/fonts/inter-var-latin.woff2" as="font" type="font/woff2" crossorigin />
  </head>

  <body>
    <header class="hero">
      <div class="hero-inner">
        <a href="/" class="back">← KitchenXpert</a>
        <h1>Guides cuisine</h1>
        <p>
          {all.length} articles indépendants — layouts, cuisinistes,
          budgets, styles. Sans pub, sans contenu sponsorisé.
        </p>
        <div class="search-wrap">
          <input
            id="search"
            type="search"
            placeholder="Rechercher un guide…"
            aria-label="Rechercher dans les guides"
          />
        </div>
      </div>
    </header>

    <main class="hub">
      {collectionOrder.map((col) => {
        const items = grouped[col] ?? [];
        if (items.length === 0) return null;
        return (
          <section class="group" data-group={col}>
            <h2>{COLLECTION_LABEL[col]} <span class="count">{items.length}</span></h2>
            <ul class="grid">
              {items
                .sort((a, b) => +b.data.publishedAt - +a.data.publishedAt)
                .map((entry) => (
                  <li>
                    <a
                      href={`/${COLLECTION_PATH[entry.collection]}/${entry.slug}`}
                      class="card"
                      data-search-text={`${entry.data.title} ${entry.data.description} ${entry.data.keywords.join(' ')}`.toLowerCase()}
                    >
                      <div class="card-title">{entry.data.title}</div>
                      <div class="card-desc">{entry.data.description}</div>
                      <div class="card-meta">
                        {entry.data.keywords.slice(0, 3).map((k) => (
                          <span class="tag">{k}</span>
                        ))}
                      </div>
                    </a>
                  </li>
                ))}
            </ul>
          </section>
        );
      })}
    </main>

    <script>
      // Vanilla client-side filter — no framework, ~25 lines.
      const input = document.getElementById('search');
      if (input instanceof HTMLInputElement) {
        const cards = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-search-text]'));
        input.addEventListener('input', () => {
          const q = input.value.trim().toLowerCase();
          for (const card of cards) {
            const text = card.dataset.searchText || '';
            const li = card.closest('li');
            if (li instanceof HTMLLIElement) {
              li.hidden = q.length > 0 && !text.includes(q);
            }
          }
          // Hide whole groups when all their items are filtered out.
          document.querySelectorAll<HTMLElement>('[data-group]').forEach((g) => {
            const visible = g.querySelectorAll('li:not([hidden])').length;
            g.hidden = visible === 0;
          });
        });
      }
    </script>

    <style>
      :root { font-family: 'Inter', system-ui, sans-serif; color-scheme: dark; }
      html, body { margin: 0; background: #0a0a0f; color: #fff; min-height: 100%; }

      .hero {
        background: linear-gradient(180deg, rgba(99,102,241,0.15) 0%, transparent 80%);
        padding: 4rem 1.5rem 3rem;
      }
      .hero-inner { max-width: 1100px; margin: 0 auto; }
      .back { color: rgba(255,255,255,0.6); text-decoration: none; font-size: 0.875rem; }
      .back:hover { color: #fff; }
      .hero h1 {
        margin: 1.5rem 0 0.75rem;
        font-size: clamp(2.5rem, 5vw, 3.5rem);
        font-weight: 600;
        background: linear-gradient(180deg, #fff 0%, rgba(255,255,255,0.6) 100%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        letter-spacing: -0.02em;
      }
      .hero p { color: rgba(255,255,255,0.65); max-width: 640px; line-height: 1.6; }
      .search-wrap { margin-top: 2rem; max-width: 480px; }
      #search {
        width: 100%;
        padding: 0.75rem 1rem;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 0.75rem;
        color: #fff;
        font-size: 0.9375rem;
      }
      #search:focus {
        outline: none;
        border-color: rgba(167,139,250,0.5);
        background: rgba(255,255,255,0.08);
      }

      .hub { max-width: 1100px; margin: 0 auto; padding: 3rem 1.5rem 4rem; }
      .group { margin-bottom: 4rem; }
      .group h2 {
        font-size: 1.5rem;
        margin: 0 0 1.5rem;
        display: flex;
        align-items: baseline;
        gap: 0.75rem;
      }
      .count {
        padding: 0.125rem 0.5rem;
        background: rgba(167,139,250,0.15);
        color: #c4b5fd;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 500;
      }
      .grid {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        list-style: none;
        margin: 0;
        padding: 0;
      }
      .card {
        display: block;
        padding: 1.25rem;
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 0.75rem;
        background: rgba(255,255,255,0.02);
        color: #fff;
        text-decoration: none;
        height: 100%;
        transition: border-color 0.18s, background 0.18s, transform 0.18s;
      }
      .card:hover {
        border-color: rgba(167,139,250,0.4);
        background: rgba(255,255,255,0.05);
        transform: translateY(-2px);
      }
      .card-title { font-size: 1rem; font-weight: 600; line-height: 1.3; margin-bottom: 0.5rem; }
      .card-desc { color: rgba(255,255,255,0.6); font-size: 0.875rem; line-height: 1.5; }
      .card-meta { margin-top: 0.75rem; display: flex; flex-wrap: wrap; gap: 0.375rem; }
      .tag {
        font-size: 0.6875rem;
        padding: 0.125rem 0.5rem;
        border-radius: 999px;
        background: rgba(255,255,255,0.06);
        color: rgba(255,255,255,0.7);
      }
    </style>
  </body>
</html>
