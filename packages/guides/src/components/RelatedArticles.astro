---
/**
 * RelatedArticles — 3 cards at the bottom of every article.
 *
 * Two modes:
 *   1. Explicit — pass `slugs={['cuisine-en-l', 'budget-10000']}`
 *   2. Automatic — pass `tags={['scandinave','budget']}` and we compute
 *      the top-3 articles sharing the most tags (Jaccard).
 */
import { getCollection, type CollectionEntry } from 'astro:content';

type AnyEntry =
  | CollectionEntry<'layouts'>
  | CollectionEntry<'cuisinistes'>
  | CollectionEntry<'budgets'>
  | CollectionEntry<'styles'>
  | CollectionEntry<'comparatifs'>
  | CollectionEntry<'pratiques'>;

interface Props {
  slugs?: string[];
  tags?: string[];
  excludeSlug?: string;
  /** Heading override (defaults to French label). */
  heading?: string;
}

const { slugs, tags, excludeSlug, heading = 'À lire ensuite' } = Astro.props;

// Pull every collection in parallel; Astro's getCollection is cached.
const all = (
  await Promise.all([
    getCollection('layouts'),
    getCollection('cuisinistes'),
    getCollection('budgets'),
    getCollection('styles'),
    getCollection('comparatifs'),
    getCollection('pratiques'),
  ])
).flat() as AnyEntry[];

const visible = all.filter(
  (e) => !e.data.draft && (!excludeSlug || e.slug !== excludeSlug),
);

let picked: AnyEntry[];
if (slugs && slugs.length) {
  picked = slugs
    .map((s) => visible.find((e) => e.slug === s))
    .filter((x): x is AnyEntry => Boolean(x));
} else if (tags && tags.length) {
  const tagSet = new Set(tags);
  picked = visible
    .map((e) => {
      const overlap = e.data.keywords.filter((k) => tagSet.has(k)).length;
      return { e, overlap };
    })
    .filter((x) => x.overlap > 0)
    .sort((a, b) => b.overlap - a.overlap)
    .slice(0, 3)
    .map((x) => x.e);
} else {
  // Fall back to the 3 most-recently-published articles.
  picked = visible
    .sort((a, b) => +b.data.publishedAt - +a.data.publishedAt)
    .slice(0, 3);
}

// Astro's collection slug doesn't include the collection name; build the URL.
const collectionToPath: Record<string, string> = {
  layouts: '/guides',
  cuisinistes: '/cuisinistes',
  budgets: '/budget',
  styles: '/styles',
  comparatifs: '/comparatifs',
  pratiques: '/guides',
};
const urlOf = (e: AnyEntry) => `${collectionToPath[e.collection]}/${e.slug}`;
---

{picked.length > 0 && (
  <section class="related" aria-labelledby="related-heading">
    <h2 id="related-heading">{heading}</h2>
    <div class="cards">
      {picked.map((e) => (
        <a href={urlOf(e)} class="card">
          <div class="card-cat">{e.collection}</div>
          <div class="card-title">{e.data.title}</div>
          <div class="card-desc">{e.data.description}</div>
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .related {
    margin-top: 5rem;
    padding-top: 3rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
  .related h2 {
    margin: 0 0 1.5rem;
    font-size: 1.5rem;
    font-weight: 600;
    color: #fff;
  }
  .cards {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(3, 1fr);
  }
  @media (max-width: 767px) {
    .cards { grid-template-columns: 1fr; }
  }
  .card {
    display: block;
    padding: 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.75rem;
    background: rgba(255, 255, 255, 0.02);
    color: #fff;
    text-decoration: none;
    transition: border-color 0.18s, background 0.18s, transform 0.18s;
  }
  .card:hover {
    border-color: rgba(255, 255, 255, 0.25);
    background: rgba(255, 255, 255, 0.05);
    transform: translateY(-2px);
  }
  .card-cat {
    color: #c4b5fd;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
  }
  .card-title {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: 0.5rem;
  }
  .card-desc {
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.875rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
