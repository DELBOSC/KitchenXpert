---
/**
 * CTABlock — call-to-action towards the sandbox designer.
 *
 * Two variants: `inline` (mid-article, smaller) and `final` (end of
 * article, full-bleed). Both link to /designer/sandbox + ping
 * Plausible with the article slug as a custom prop so we can build
 * the conversion funnel per article.
 */

interface Props {
  variant?: 'inline' | 'final';
  /** Slug of the source article — for analytics attribution. */
  fromSlug: string;
  /** Override the default headline. */
  headline?: string;
  /** Override the default subline. */
  subline?: string;
}

const { variant = 'inline', fromSlug, headline, subline } = Astro.props;

const isFinal = variant === 'final';
const defaultHeadline = isFinal
  ? 'Concevez votre cuisine en 5 minutes'
  : 'Visualisez ce layout en 3D';
const defaultSubline = isFinal
  ? 'Designer 3D temps réel · Catalogue IKEA + 4 fournisseurs · Sans création de compte'
  : 'Sans inscription, sans CB. Vous gardez votre projet en local.';

const targetUrl = `/designer/sandbox?utm_source=guides&utm_medium=cta&utm_campaign=${encodeURIComponent(fromSlug)}`;
---

<a
  href={targetUrl}
  class:list={['cta-block', { final: isFinal }]}
  data-plausible-event-name="guides_cta_click"
  data-plausible-event-source={fromSlug}
  data-plausible-event-variant={variant}
>
  <div class="cta-text">
    <div class="cta-headline">{headline ?? defaultHeadline}</div>
    <div class="cta-subline">{subline ?? defaultSubline}</div>
  </div>
  <div class="cta-arrow" aria-hidden>→</div>
</a>

<style>
  .cta-block {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    margin: 2.5rem 0;
    padding: 1.5rem 1.75rem;
    border-radius: 1rem;
    border: 1px solid rgba(167, 139, 250, 0.25);
    background: linear-gradient(135deg,
      rgba(99, 102, 241, 0.12) 0%,
      rgba(236, 72, 153, 0.08) 100%);
    backdrop-filter: blur(12px);
    color: #fff;
    text-decoration: none;
    transition: transform 0.18s, border-color 0.18s, box-shadow 0.18s;
  }
  .cta-block:hover {
    transform: translateY(-2px);
    border-color: rgba(167, 139, 250, 0.5);
    box-shadow: 0 12px 40px rgba(167, 139, 250, 0.18);
  }
  .cta-block.final {
    margin: 4rem 0 2rem;
    padding: 2.5rem;
    flex-direction: column;
    text-align: center;
  }
  .cta-headline {
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.3;
  }
  .cta-block.final .cta-headline {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .cta-subline {
    margin-top: 0.25rem;
    color: rgba(255, 255, 255, 0.65);
    font-size: 0.875rem;
  }
  .cta-arrow {
    flex-shrink: 0;
    font-size: 1.5rem;
    color: #c4b5fd;
    transition: transform 0.18s;
  }
  .cta-block:hover .cta-arrow { transform: translateX(4px); }
  .cta-block.final .cta-arrow {
    margin-top: 1rem;
    padding: 0.5rem 1.5rem;
    border-radius: 999px;
    background: #fff;
    color: #1e293b;
    font-weight: 600;
  }
</style>
