---
/**
 * LegalDisclaimer — pied de page obligatoire des comparatifs
 * concurrents. Conforme aux 6 critères du Code de la consommation
 * art. L122-1 à L122-4 (publicité comparative licite).
 *
 * Présent sur TOUTES les pages /comparatifs/vs-* sans exception.
 *
 * Si Laurent doit défendre une page comparative en justice, c'est ce
 * disclaimer + les sources datées de competitor-facts.json qui font
 * preuve de bonne foi.
 */

interface Props {
  competitorName: string;
  verdictDate: Date;
  /** Lien vers le site officiel du concurrent. */
  competitorUrl: string;
}

const { competitorName, verdictDate, competitorUrl } = Astro.props;

const fmt = new Intl.DateTimeFormat('fr-FR', {
  day: 'numeric', month: 'long', year: 'numeric',
}).format(verdictDate);

// Calcul de la fraîcheur — plus de 90 j = avertissement visuel
const ageMs = Date.now() - verdictDate.getTime();
const stale = ageMs > 90 * 24 * 60 * 60 * 1000;
---

<aside
  role="note"
  aria-label="Mentions légales du comparatif"
  class={`disclaimer ${stale ? 'stale' : ''}`}
>
  <h3>Conformité &amp; transparence</h3>

  <ul>
    <li>
      <strong>Comparatif factuel</strong> basé sur les fonctionnalités publiées
      par chaque éditeur au <time datetime={verdictDate.toISOString()}>{fmt}</time>.
      {stale && (
        <span class="stale-badge">⚠️ Données &gt; 90 jours — re-vérification en cours</span>
      )}
    </li>
    <li>
      Sources : chaque ✅ / ⚠️ / ❌ du tableau renvoie au document officiel du
      concurrent (icône <span aria-hidden>↗</span>) ou de KitchenXpert.
    </li>
    <li>
      <strong>{competitorName}</strong> est la propriété de ses détenteurs respectifs.
      Site officiel :{' '}
      <a href={competitorUrl} target="_blank" rel="noopener noreferrer">
        {new URL(competitorUrl).hostname}
      </a>.
    </li>
    <li>
      KitchenXpert est un éditeur logiciel <strong>indépendant</strong>, sans
      affiliation commerciale, sponsoring ou partenariat avec {competitorName}.
    </li>
    <li>
      Conformément à <a href="https://www.legifrance.gouv.fr/codes/article_lc/LEGIARTI000032227166/" target="_blank" rel="noopener noreferrer">l'article L122-1 du Code de la consommation</a>,
      ce comparatif porte sur des biens ou services répondant aux mêmes besoins,
      compare des caractéristiques essentielles, pertinentes, vérifiables et représentatives,
      et n'engendre aucune confusion entre les marques.
    </li>
    <li>
      Vous constatez une erreur factuelle ?{' '}
      <a href={`mailto:legal@kitchenxpert.com?subject=Correction%20comparatif%20${encodeURIComponent(competitorName)}`}>
        Signalez-la
      </a>
      &nbsp;— mise à jour sous 7 jours ouvrés.
    </li>
  </ul>
</aside>

<style>
  .disclaimer {
    margin: 4rem 0 2rem;
    padding: 1.5rem 1.75rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 0.75rem;
    background: rgba(255, 255, 255, 0.02);
    font-size: 0.8125rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.55);
  }
  .disclaimer.stale {
    border-color: rgba(251, 191, 36, 0.25);
    background: rgba(251, 191, 36, 0.04);
  }
  .disclaimer h3 {
    margin: 0 0 0.75rem;
    color: #fff;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .disclaimer ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .disclaimer li {
    padding: 0.375rem 0 0.375rem 1rem;
    position: relative;
  }
  .disclaimer li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: rgba(255, 255, 255, 0.3);
  }
  .disclaimer a {
    color: #c4b5fd;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .stale-badge {
    display: inline-block;
    margin-left: 0.5rem;
    padding: 0.125rem 0.5rem;
    background: rgba(251, 191, 36, 0.15);
    color: #fbbf24;
    border-radius: 999px;
    font-size: 0.6875rem;
    font-weight: 500;
  }
</style>
