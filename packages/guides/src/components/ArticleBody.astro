---
/**
 * ArticleBody — typographic wrapper for MDX content.
 *
 * Sets a generous reading line-height + max-width 720px (long-form
 * sweet spot: ~70 chars/line at 18 px). Headings (h2/h3/h4) get
 * margin-top scaled by depth so the visual rhythm reads.
 */
---

<div class="article-body">
  <slot />
</div>

<style is:global>
  .article-body {
    max-width: 720px;
    margin: 0 auto;
    color: rgba(255, 255, 255, 0.86);
    font-size: 1.0625rem;
    line-height: 1.75;
  }
  .article-body :global(p) {
    margin: 0 0 1.5rem;
  }
  .article-body :global(h2) {
    margin: 3.5rem 0 1.25rem;
    font-size: 1.875rem;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.015em;
    color: #fff;
  }
  .article-body :global(h3) {
    margin: 2.75rem 0 1rem;
    font-size: 1.375rem;
    font-weight: 600;
    line-height: 1.3;
    color: #fff;
  }
  .article-body :global(h4) {
    margin: 2rem 0 0.75rem;
    font-size: 1.125rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.95);
  }
  .article-body :global(ul),
  .article-body :global(ol) {
    margin: 0 0 1.5rem;
    padding-left: 1.5rem;
  }
  .article-body :global(li) {
    margin-bottom: 0.5rem;
  }
  .article-body :global(a) {
    color: #c4b5fd;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(196, 181, 253, 0.4);
    transition: text-decoration-color 0.15s;
  }
  .article-body :global(a:hover) {
    text-decoration-color: currentColor;
  }
  .article-body :global(strong) {
    color: #fff;
    font-weight: 600;
  }
  .article-body :global(blockquote) {
    margin: 2rem 0;
    padding: 1rem 1.25rem;
    border-left: 3px solid #a78bfa;
    background: rgba(167, 139, 250, 0.08);
    border-radius: 0 0.5rem 0.5rem 0;
    color: rgba(255, 255, 255, 0.9);
    font-style: italic;
  }
  .article-body :global(code) {
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    background: rgba(255, 255, 255, 0.08);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.875em;
  }
  .article-body :global(pre) {
    margin: 1.5rem 0;
    padding: 1rem;
    overflow-x: auto;
    border-radius: 0.5rem;
    background: rgba(0, 0, 0, 0.5);
  }
  .article-body :global(img),
  .article-body :global(video) {
    margin: 2rem auto;
    max-width: 100%;
    border-radius: 0.75rem;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
  }
  .article-body :global(figcaption) {
    margin-top: 0.5rem;
    text-align: center;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.875rem;
  }
  .article-body :global(table) {
    width: 100%;
    margin: 2rem 0;
    border-collapse: collapse;
    border-radius: 0.5rem;
    overflow: hidden;
  }
  .article-body :global(th),
  .article-body :global(td) {
    padding: 0.75rem 1rem;
    text-align: left;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  .article-body :global(th) {
    background: rgba(255, 255, 255, 0.04);
    color: #fff;
    font-weight: 600;
    font-size: 0.875rem;
  }
</style>
