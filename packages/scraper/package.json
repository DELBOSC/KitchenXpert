{
  "name": "@kitchenxpert/scraper",
  "version": "1.0.0",
  "private": true,
  "description": "Kitchen furniture and appliance catalog scraper for KitchenXpert",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "scrape:all": "ts-node scripts/scrape-all.ts",
    "scrape:brand": "ts-node scripts/scrape-brand.ts",
    "scrape:test": "ts-node scripts/scrape-brand.ts --test",
    "scrape:priority": "ts-node scripts/scrape-all.ts --priority",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "ts-node src/database/seed.ts",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "export:json": "ts-node scripts/export.ts --format json",
    "export:csv": "ts-node scripts/export.ts --format csv",
    "export:kitchenxpert": "ts-node scripts/export.ts --format kitchenxpert",
    "update:prices": "ts-node scripts/update-prices.ts",
    "check:urls": "ts-node scripts/check-urls.ts",
    "clean:duplicates": "ts-node scripts/clean-duplicates.ts",
    "api:start": "ts-node src/api/server.ts",
    "api:dev": "nodemon --exec ts-node src/api/server.ts",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kitchenxpert/common": "workspace:*",
    "puppeteer": "^22.0.0",
    "cheerio": "^1.0.0-rc.12",
    "axios": "^1.6.5",
    "@prisma/client": "^5.10.0",
    "ioredis": "^5.3.0",
    "bullmq": "^5.0.0",
    "express": "^4.18.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "winston": "^3.11.0",
    "dotenv": "^16.4.0",
    "date-fns": "^3.3.0",
    "lodash": "^4.17.21",
    "p-limit": "^5.0.0",
    "p-retry": "^6.2.0",
    "p-queue": "^8.0.1",
    "zod": "^3.22.4",
    "sharp": "^0.33.2",
    "mime-types": "^2.1.35",
    "robots-parser": "^3.0.1",
    "user-agents": "^1.1.0"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.19.33",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/lodash": "^4.14.202",
    "@types/mime-types": "^2.1.4",
    "ts-node": "^10.9.0",
    "nodemon": "^3.1.14",
    "vitest": "^3.2.6",
    "@vitest/coverage-v8": "^3.2.6",
    "prisma": "^5.10.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "prettier": "^3.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "KitchenXpert",
  "license": "PROPRIETARY"
}
