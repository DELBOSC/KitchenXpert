# ==============================================
# KitchenXpert Scraper - Environment Configuration
# ==============================================
# Copy this file to .env and fill in the values
# Variables marked with [REQUIRED] must be set

# ==============================================
# DATABASE [REQUIRED]
# ==============================================
DATABASE_URL=postgresql://kitchenxpert:kitchenxpert@localhost:5432/kitchenxpert_scraper?schema=public

# ==============================================
# REDIS [REQUIRED]
# ==============================================
REDIS_URL=redis://localhost:6379

# ==============================================
# API SERVER [REQUIRED]
# ==============================================
API_PORT=3100
API_HOST=localhost
NODE_ENV=development

# ==============================================
# SCRAPING CONFIGURATION [REQUIRED]
# ==============================================
# Rate limiting between requests (in milliseconds)
SCRAPE_RATE_LIMIT_MS=3000

# Maximum concurrent scraping operations
SCRAPE_MAX_CONCURRENT=3

# Number of retry attempts for failed requests
SCRAPE_RETRY_ATTEMPTS=3

# Request timeout (in milliseconds)
SCRAPE_TIMEOUT_MS=30000

# User agent string for HTTP requests
SCRAPE_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/121.0.0.0 Safari/537.36

# ==============================================
# PROXY CONFIGURATION [OPTIONAL]
# ==============================================
PROXY_ENABLED=false
PROXY_LIST=
PROXY_ROTATION_ENABLED=false

# ==============================================
# IMAGE STORAGE [OPTIONAL]
# ==============================================
IMAGE_STORAGE_PATH=./data/images
IMAGE_MAX_WIDTH=1200
IMAGE_QUALITY=85

# ==============================================
# LOGGING [RECOMMENDED]
# ==============================================
LOG_LEVEL=info
LOG_FILE_PATH=./logs
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

# ==============================================
# DEBUG [DEVELOPMENT ONLY]
# ==============================================
DEBUG_SCREENSHOTS=false
DEBUG_SCREENSHOTS_PATH=./data/debug

# ==============================================
# API KEYS [OPTIONAL]
# ==============================================
# Some sites may require API keys for access
# IKEA_API_KEY=
