{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "@kitchenxpert/backend",
  "extends": "../../tsconfig.node.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    // Without `baseUrl` (deprecated), path values are resolved relative
    // to this tsconfig file. We prefix every entry with `./src/`.
    "paths": {
      "@/*": ["./src/*"],
      "@/controllers/*": ["./src/controllers/*"],
      "@/services/*": ["./src/services/*"],
      "@/models/*": ["./src/models/*"],
      "@/middlewares/*": ["./src/middlewares/*"],
      "@/repositories/*": ["./src/repositories/*"],
      "@/utils/*": ["./src/utils/*"],
      "@/config/*": ["./src/config/*"],
      "@/types/*": ["./src/types/*"],
      "@kitchenxpert/common": ["../common/src"],
      "@kitchenxpert/common/*": ["../common/src/*"]
    },
    "types": ["node", "jest"],
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"],
  "references": [
    { "path": "../common" }
  ]
}
