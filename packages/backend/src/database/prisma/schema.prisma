// KitchenXpert - Prisma Database Schema
// Production-ready schema with all domain models

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserStatus {
  pending
  active
  suspended
  deleted
}

enum ProjectStatus {
  draft
  in_progress
  review
  approved
  completed
  archived
}

enum OrderStatus {
  pending
  confirmed
  processing
  shipped
  delivered
  cancelled
  refunded
}

enum KitchenStyle {
  modern
  traditional
  farmhouse
  industrial
  transitional
  coastal
  contemporary
  scandinavian
  mediterranean
  rustic
}

enum LayoutType {
  l_shaped
  u_shaped
  galley
  island
  peninsula
  one_wall
  open_plan
}

enum NotificationType {
  info
  warning
  error
  success
  system
}

enum WebhookEventType {
  project_created
  project_updated
  project_completed
  order_created
  order_updated
  user_registered
  kitchen_generated
}

enum AuditAction {
  create
  read
  update
  delete
  login
  logout
  export
  import
  payment_succeeded
  payment_failed
  subscription_created
  subscription_updated
  subscription_deleted
  invoice_paid
  invoice_payment_failed
  charge_refunded
}

// ==================== USER MANAGEMENT ====================

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  password      String
  firstName     String
  lastName      String
  role          String     @default("user")
  status        UserStatus @default(pending)
  emailVerified Boolean    @default(false)
  language      String     @default("fr")
  timezone      String     @default("UTC")
  avatar        String?
  phone         String?
  lastLoginAt   DateTime?
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  stripeCustomerId   String?   @unique
  subscriptionId     String?
  subscriptionStatus String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  // Relations
  userRoles               UserRole[]
  projects                Project[]
  kitchens                Kitchen[]
  orders                  Order[]
  auditLogs               AuditLog[]
  notifications           Notification[]
  preferences             UserPreference?
  sessions                UserSession[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  aiChatSessions          AIChatSession[]
  aiUsageLogs             AIUsageLog[]
  aiGenerations           AIGeneration[]
  designRatings           DesignRating[]
  projectComments         ProjectComment[]
  designVersions          DesignVersion[]

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@index([name])
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  resource    String
  action      String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@index([resource])
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  // Relations
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model UserPreference {
  id                  String   @id @default(uuid())
  userId              String   @unique
  theme               String   @default("light")
  notificationsEmail  Boolean  @default(true)
  notificationsPush   Boolean  @default(true)
  measurementUnit     String   @default("metric")
  currency            String   @default("EUR")
  defaultStyle        KitchenStyle?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSession {
  id           String   @id @default(uuid())
  userId       String
  token        String   @unique
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique  // Hashed token for security
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique  // Hashed token for security
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

// ==================== PROJECT & KITCHEN ====================

model Project {
  id          String        @id @default(uuid())
  userId      String
  name        String
  description String?
  status      ProjectStatus @default(draft)
  budget      Decimal?      @db.Decimal(12, 2)
  currency    String        @default("EUR")
  deadline    DateTime?
  metadata    Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  // Relations
  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  kitchens           Kitchen[]
  orders             Order[]
  collaborators      ProjectCollaborator[]
  questionnaireResponse QuestionnaireResponse?
  aiGenerations         AIGeneration[]
  comments              ProjectComment[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model ProjectCollaborator {
  id        String   @id @default(uuid())
  projectId String
  email     String
  role      String   @default("viewer")
  invitedAt DateTime @default(now())
  acceptedAt DateTime?

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, email])
  @@index([projectId])
}

model Kitchen {
  id          String       @id @default(uuid())
  projectId   String
  userId      String
  name        String
  style       KitchenStyle @default(modern)
  layout      LayoutType   @default(l_shaped)
  width       Decimal      @db.Decimal(8, 2)
  length      Decimal      @db.Decimal(8, 2)
  height      Decimal      @db.Decimal(8, 2) @default(2.50)
  isGenerated Boolean      @default(false)
  score       Int?
  metadata    Json?
  thumbnail   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  // Relations
  project        Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  configuration  KitchenConfiguration?
  items          KitchenItem[]
  designs        DesignPreference?
  ratings        DesignRating[]
  versions       DesignVersion[]

  @@index([projectId])
  @@index([userId])
  @@index([style])
  @@index([createdAt])
}

model KitchenConfiguration {
  id                String   @id @default(uuid())
  kitchenId         String   @unique
  cabinetStyle      String?
  cabinetFinish     String?
  countertopMaterial String?
  countertopColor   String?
  backsplashType    String?
  backsplashMaterial String?
  flooringType      String?
  hardwareStyle     String?
  hardwareFinish    String?
  lightingPlan      Json?
  colorPalette      Json?
  appliances        Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  kitchen Kitchen @relation(fields: [kitchenId], references: [id], onDelete: Cascade)
}

model KitchenItem {
  id          String   @id @default(uuid())
  kitchenId   String
  productId   String?
  applianceId String?
  type        String
  name        String
  brand       String?
  model       String?
  positionX   Decimal  @db.Decimal(8, 2)
  positionY   Decimal  @db.Decimal(8, 2)
  positionZ   Decimal  @db.Decimal(8, 2) @default(0)
  rotationY   Decimal  @db.Decimal(8, 2) @default(0)
  width       Decimal  @db.Decimal(8, 2)
  depth       Decimal  @db.Decimal(8, 2)
  height      Decimal  @db.Decimal(8, 2)
  price       Decimal? @db.Decimal(12, 2)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  kitchen   Kitchen    @relation(fields: [kitchenId], references: [id], onDelete: Cascade)
  product   Product?   @relation(fields: [productId], references: [id])
  appliance Appliance? @relation(fields: [applianceId], references: [id])

  @@index([kitchenId])
  @@index([productId])
  @@index([applianceId])
  @@index([type])
}

model DesignPreference {
  id                    String   @id @default(uuid())
  kitchenId             String   @unique
  colorScheme           String?
  materialPreferences   Json?
  styleInfluences       Json?
  budgetPriorities      Json?
  functionalPriorities  Json?
  aestheticScore        Int?
  coherenceScore        Int?
  personaMatch          String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  kitchen Kitchen @relation(fields: [kitchenId], references: [id], onDelete: Cascade)
}

// ==================== CATALOG & PRODUCTS ====================

model Catalog {
  id          String   @id @default(uuid())
  providerId  String
  name        String
  description String?
  version     String   @default("1.0")
  isActive    Boolean  @default(true)
  lastSyncAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  provider CatalogProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([providerId])
  @@index([isActive])
}

model CatalogProvider {
  id             String   @id @default(uuid())
  name           String   @unique
  code           String   @unique
  apiEndpoint    String?
  apiKey         String?
  isActive       Boolean  @default(true)
  configuration  Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  catalogs   Catalog[]
  products   Product[]
  appliances Appliance[]
  materials  Material[]

  @@index([code])
  @@index([isActive])
}

model Product {
  id           String   @id @default(uuid())
  catalogId    String?
  providerId   String?
  categoryId   String?
  sku          String   @unique
  name         String
  description  String?
  brand        String?
  model        String?
  price        Decimal  @db.Decimal(12, 2)
  currency     String   @default("EUR")
  width        Decimal? @db.Decimal(8, 2)
  depth        Decimal? @db.Decimal(8, 2)
  height       Decimal? @db.Decimal(8, 2)
  weight       Decimal? @db.Decimal(8, 2)
  color        String?
  material     String?
  finish       String?
  images       Json?
  specifications Json?
  availability String   @default("in_stock")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  // Relations
  catalog      Catalog?         @relation(fields: [catalogId], references: [id])
  provider     CatalogProvider? @relation(fields: [providerId], references: [id])
  category     ProductCategory? @relation(fields: [categoryId], references: [id])
  kitchenItems KitchenItem[]
  orderItems   OrderItem[]

  @@index([catalogId])
  @@index([providerId])
  @@index([categoryId])
  @@index([sku])
  @@index([brand])
  @@index([name])
  @@index([isActive])
}

model ProductCategory {
  id          String   @id @default(uuid())
  parentId    String?
  name        String
  slug        String   @unique
  description String?
  image       String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  parent   ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ProductCategory[] @relation("CategoryHierarchy")
  products Product[]

  @@index([parentId])
  @@index([slug])
  @@index([isActive])
}

model Appliance {
  id              String   @id @default(uuid())
  providerId      String?
  type            String
  brand           String
  model           String
  name            String
  description     String?
  price           Decimal  @db.Decimal(12, 2)
  currency        String   @default("EUR")
  energyRating    String?
  powerConsumption Decimal? @db.Decimal(8, 2)
  width           Decimal  @db.Decimal(8, 2)
  depth           Decimal  @db.Decimal(8, 2)
  height          Decimal  @db.Decimal(8, 2)
  weight          Decimal? @db.Decimal(8, 2)
  color           String?
  finish          String?
  features        Json?
  specifications  Json?
  images          Json?
  smartFeatures   Json?
  warranty        String?
  availability    String   @default("in_stock")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  // Relations
  provider     CatalogProvider? @relation(fields: [providerId], references: [id])
  kitchenItems KitchenItem[]
  orderItems   OrderItem[]

  @@unique([brand, model])
  @@index([providerId])
  @@index([type])
  @@index([brand])
  @@index([isActive])
}

model Material {
  id              String   @id @default(uuid())
  providerId      String?
  type            String
  name            String
  description     String?
  category        String
  pricePerUnit    Decimal  @db.Decimal(12, 2)
  unit            String   @default("sqm")
  currency        String   @default("EUR")
  color           String?
  finish          String?
  durability      Int?
  maintenanceLevel String?
  ecoRating       String?
  specifications  Json?
  images          Json?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  provider CatalogProvider? @relation(fields: [providerId], references: [id])

  @@index([providerId])
  @@index([type])
  @@index([name])
  @@index([category])
  @@index([isActive])
}

// ==================== ORDERS ====================

model Order {
  id              String      @id @default(uuid())
  userId          String
  projectId       String?
  orderNumber     String      @unique
  status          OrderStatus @default(pending)
  subtotal        Decimal     @db.Decimal(12, 2)
  tax             Decimal     @db.Decimal(12, 2) @default(0)
  shipping        Decimal     @db.Decimal(12, 2) @default(0)
  discount        Decimal     @db.Decimal(12, 2) @default(0)
  total           Decimal     @db.Decimal(12, 2)
  currency        String      @default("EUR")
  shippingAddress Json?
  billingAddress  Json?
  notes           String?
  metadata        Json?
  paidAt          DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project?    @relation(fields: [projectId], references: [id])
  items   OrderItem[]

  @@index([userId])
  @@index([projectId])
  @@index([orderNumber])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  productId   String?
  applianceId String?
  name        String
  sku         String?
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(12, 2)
  totalPrice  Decimal  @db.Decimal(12, 2)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  order     Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product?   @relation(fields: [productId], references: [id])
  appliance Appliance? @relation(fields: [applianceId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([applianceId])
}

// ==================== PARTNER ====================

model Partner {
  id              String   @id @default(uuid())
  name            String
  code            String   @unique
  email           String   @unique
  phone           String?
  website         String?
  apiKey          String   @unique
  apiSecret       String
  isActive        Boolean  @default(true)
  commissionRate  Decimal  @db.Decimal(5, 2) @default(0)
  configuration   Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  integrations PartnerIntegration[]
  webhooks     Webhook[]

  @@index([code])
  @@index([apiKey])
  @@index([isActive])
}

model PartnerIntegration {
  id            String   @id @default(uuid())
  partnerId     String
  type          String
  endpoint      String
  credentials   Json?
  configuration Json?
  isActive      Boolean  @default(true)
  lastSyncAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@index([type])
  @@index([isActive])
}

// ==================== QUESTIONNAIRE ====================

model QuestionnaireResponse {
  id               String   @id @default(uuid())
  projectId        String   @unique
  spatialData      Json?
  cookingHabits    Json?
  userProfile      Json?
  budgetData       Json?
  socialUsage      Json?
  futureNeeds      Json?
  aestheticPrefs   Json?
  technologyPrefs  Json?
  environmentalPrefs Json?
  maintenancePrefs Json?
  completedSections String[] @default([])
  currentSection   String?
  completedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scoringResult ScoringResult?
}

model ScoringResult {
  id                     String   @id @default(uuid())
  questionnaireId        String   @unique
  overallScore           Int
  spatialScore           Int?
  cookingScore           Int?
  budgetScore            Int?
  socialScore            Int?
  futureNeedsScore       Int?
  aestheticScore         Int?
  technologyScore        Int?
  environmentalScore     Int?
  maintenanceScore       Int?
  designPersona          String?
  techPersona            String?
  ecoPersona             String?
  maintenancePersona     String?
  recommendations        Json?
  warnings               Json?
  tags                   String[] @default([])
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  // Relations
  questionnaire QuestionnaireResponse @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
}

// ==================== SYSTEM & AUDIT ====================

model AuditLog {
  id          String      @id @default(uuid())
  userId      String?
  action      AuditAction
  resource    String
  resourceId  String?
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime    @default(now())

  // Relations
  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([resourceId])
  @@index([createdAt])
}

model Webhook {
  id          String           @id @default(uuid())
  partnerId   String?
  name        String
  url         String
  secret      String
  events      WebhookEventType[]
  isActive    Boolean          @default(true)
  retryCount  Int              @default(3)
  timeout     Int              @default(30000)
  headers     Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // Relations
  partner   Partner?       @relation(fields: [partnerId], references: [id])
  eventLogs WebhookEvent[]

  @@index([partnerId])
  @@index([isActive])
}

model WebhookEvent {
  id          String   @id @default(uuid())
  webhookId   String
  eventType   WebhookEventType
  payload     Json
  response    Json?
  statusCode  Int?
  attempts    Int      @default(0)
  deliveredAt DateTime?
  failedAt    DateTime?
  error       String?
  createdAt   DateTime @default(now())

  // Relations
  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([eventType])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType @default(info)
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
}

model Locale {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  nativeName String
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  translations Translation[]

  @@index([code])
  @@index([isActive])
}

model Translation {
  id        String   @id @default(uuid())
  localeId  String
  namespace String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  locale Locale @relation(fields: [localeId], references: [id], onDelete: Cascade)

  @@unique([localeId, namespace, key])
  @@index([localeId])
  @@index([namespace])
}

model Metric {
  id        String   @id @default(uuid())
  name      String
  value     Decimal  @db.Decimal(20, 4)
  unit      String?
  tags      Json?
  metadata  Json?
  timestamp DateTime @default(now())

  @@index([name])
  @@index([timestamp])
}

// ==================== AI & SOCIAL FEATURES ====================

model AIChatSession {
  id           String   @id @default(uuid())
  userId       String
  kitchenId    String?
  title        String?
  messages     Json
  sceneContext Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([kitchenId])
}

model AIUsageLog {
  id           String   @id @default(uuid())
  userId       String
  service      String
  model        String
  inputTokens  Int
  outputTokens Int
  durationMs   Int?
  metadata     Json?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([service])
  @@index([createdAt])
}

model AIGeneration {
  id            String    @id @default(uuid())
  userId        String
  projectId     String?
  status        String    @default("pending")
  preferences   Json
  designs       Json
  isAIGenerated Boolean   @default(false)
  errorMessage  String?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id])

  @@index([userId])
  @@index([projectId])
  @@index([status])
}

model DesignRating {
  id        String   @id @default(uuid())
  userId    String
  kitchenId String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  kitchen Kitchen @relation(fields: [kitchenId], references: [id], onDelete: Cascade)

  @@unique([userId, kitchenId])
  @@index([kitchenId])
}

model ProjectComment {
  id        String    @id @default(uuid())
  projectId String
  userId    String
  parentId  String?
  content   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  project Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
