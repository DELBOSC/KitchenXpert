{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "@kitchenxpert/common",
  "extends": "../../tsconfig.lib.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    // baseUrl removed (deprecated). No `paths` here, so nothing else to do.
    // module + moduleResolution come from tsconfig.lib.json
    // (ESNext + bundler) — the modern, deprecation-free combo for a
    // library consumed by other workspace packages.
    "lib": ["ES2022", "DOM"],
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"]
}
