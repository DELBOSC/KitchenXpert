{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "@kitchenxpert/design-system",
  "extends": "../../tsconfig.react.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./src",
    "jsx": "react-jsx",
    "paths": {
      "@kitchenxpert/common": ["../../packages/common/src"],
      "@kitchenxpert/common/*": ["../../packages/common/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "storybook-static",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.stories.tsx"
  ],
  "references": [{ "path": "../common" }]
}
