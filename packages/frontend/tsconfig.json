{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "@kitchenxpert/frontend",
  "extends": "../../tsconfig.react.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    // baseUrl removed (deprecated). Path values now embed `./src/`, and
    // workspace-package values use sibling `../<pkg>/src` directories.
    "types": ["vite/client", "node"],
    "paths": {
      "@/*": ["./src/*"],
      "@/components/*": ["./src/components/*"],
      "@/pages/*": ["./src/pages/*"],
      "@/hooks/*": ["./src/hooks/*"],
      "@/utils/*": ["./src/utils/*"],
      "@/stores/*": ["./src/stores/*"],
      "@/types/*": ["./src/types/*"],
      "@/styles/*": ["./src/styles/*"],
      "@kitchenxpert/common": ["../common/src"],
      "@kitchenxpert/common/*": ["../common/src/*"],
      "@kitchenxpert/api-client": ["../api-client/src"],
      "@kitchenxpert/api-client/*": ["../api-client/src/*"],
      "@kitchenxpert/design-system": ["../design-system/src"],
      "@kitchenxpert/design-system/*": ["../design-system/src/*"],
      "@kitchenxpert/ui-components": ["../ui-components/src"],
      "@kitchenxpert/ui-components/*": ["../ui-components/src/*"],
      "@kitchenxpert/3d-engine": ["../3d-engine/src"],
      "@kitchenxpert/3d-engine/*": ["../3d-engine/src/*"]
    }
  },
  "include": ["src/**/*", "src/**/*.json"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.test.tsx", "src/test/**/*", "src/__tests__/**/*"],
  "references": [
    { "path": "../common" },
    { "path": "../api-client" },
    { "path": "../design-system" },
    { "path": "../ui-components" },
    { "path": "../3d-engine" }
  ]
}
