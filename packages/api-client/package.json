    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@kitchenxpert/common": "workspace:*",
    "axios": "^1.6.5"
  },
  "devDependencies": {
    "@types/node": "^20.19.33",
    "typescript": "^5.3.3",
    "@types/jest": "^29.5.11",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1"
  }
}
