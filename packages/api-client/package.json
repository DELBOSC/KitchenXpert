{
  "name": "@kitchenxpert/api-client",
  "version": "1.0.0",
  "private": true,
  "description": "KitchenXpert API Client - Type-safe HTTP client for API communication",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "clean": "rm -rf dist",
