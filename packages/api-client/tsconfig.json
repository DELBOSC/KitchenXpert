{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "@kitchenxpert/api-client",
  "extends": "../../tsconfig.lib.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./src",
    "paths": {
      "@kitchenxpert/common": ["../../packages/common/src"],
      "@kitchenxpert/common/*": ["../../packages/common/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"],
  "references": [
    { "path": "../common" }
  ]
}
