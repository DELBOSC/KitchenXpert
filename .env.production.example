# =============================================================================
# KITCHENXPERT - PRODUCTION ENVIRONMENT CONFIGURATION
# =============================================================================
#
# SECURITY WARNINGS:
# - NEVER commit this file with real credentials to version control
# - NEVER use default/example values in production
# - ALWAYS use strong, randomly generated secrets
# - ALWAYS use SSL/TLS for database and Redis connections
# - ALWAYS rotate secrets periodically
#
# To generate secure secrets, use:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
# =============================================================================

# =============================================================================
# SERVER [REQUIRED]
# =============================================================================
NODE_ENV=production
PORT=4000
HOST=0.0.0.0
APP_NAME=KitchenXpert
APP_URL=https://kitchenxpert.com
API_URL=https://api.kitchenxpert.com

# =============================================================================
# DATABASE [REQUIRED]
# =============================================================================
# SECURITY: Always use SSL in production (sslmode=require)
# SECURITY: Use a strong password with special characters
# SECURITY: Restrict database user permissions to minimum required
DATABASE_URL=postgresql://kitchenxpert_user:CHANGE_THIS_STRONG_PASSWORD@your-production-db-host.rds.amazonaws.com:5432/kitchenxpert_prod?sslmode=require

DB_HOST=your-production-db-host.rds.amazonaws.com
DB_PORT=5432
DB_NAME=kitchenxpert_prod
DB_USER=kitchenxpert_user
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DB_SSL=true

# =============================================================================
# REDIS [REQUIRED]
# =============================================================================
# SECURITY: Always use authentication in production
# SECURITY: Use TLS connection (rediss://) when available
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@your-redis-host.cache.amazonaws.com:6379/0
REDIS_HOST=your-redis-host.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD
REDIS_DB=0

# =============================================================================
# JWT [REQUIRED] - CRITICAL SECURITY
# =============================================================================
# SECURITY: MUST be at least 32 characters (64+ recommended)
# SECURITY: MUST be randomly generated
# SECURITY: MUST be different for access and refresh tokens
# SECURITY: Rotate these secrets periodically
#
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_THIS_GENERATE_A_STRONG_SECRET_KEY_MIN_64_CHARS_RECOMMENDED
JWT_REFRESH_SECRET=CHANGE_THIS_GENERATE_A_DIFFERENT_STRONG_SECRET_KEY_MIN_64_CHARS
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# =============================================================================
# CORS [REQUIRED]
# =============================================================================
# SECURITY: Only allow your production domains
# SECURITY: Never use wildcards (*) in production
CORS_ORIGINS=https://kitchenxpert.com,https://www.kitchenxpert.com
CORS_ORIGIN=https://kitchenxpert.com

# =============================================================================
# EMAIL [REQUIRED for user-facing features]
# =============================================================================
# Recommended: Use SendGrid or similar transactional email service
MAIL_PROVIDER=sendgrid
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=apikey
SMTP_PASS=YOUR_SENDGRID_API_KEY
MAIL_FROM=noreply@kitchenxpert.com
EMAIL_FROM=noreply@kitchenxpert.com
SENDGRID_API_KEY=SG.YOUR_SENDGRID_API_KEY

# =============================================================================
# SECURITY SETTINGS [REQUIRED]
# =============================================================================
# SECURITY: Use higher bcrypt rounds in production (12-14 recommended)
# SECURITY: DATA_ENCRYPTION_KEY is used for AES-256-GCM encryption of API keys/secrets
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DATA_ENCRYPTION_KEY=
BCRYPT_ROUNDS=12
ENABLE_RATE_LIMIT=true
ENABLE_HELMET=true
ENABLE_CORS=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# MONITORING [REQUIRED for production]
# =============================================================================
# SECURITY: Use appropriate log level (info or warn in production)
LOG_LEVEL=info
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# =============================================================================
# PAYMENT - STRIPE [REQUIRED if using payments]
# =============================================================================
# SECURITY: Use live keys only in production
# SECURITY: Never expose secret key to frontend
STRIPE_PUBLIC_KEY=pk_live_YOUR_LIVE_PUBLIC_KEY
STRIPE_SECRET_KEY=sk_live_YOUR_LIVE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# =============================================================================
# AI SERVICES [OPTIONAL]
# =============================================================================
# SECURITY: Restrict API key permissions to minimum required
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Google Gemini — required for photorealistic kitchen image generation
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_GENAI_API_KEY=YOUR_GOOGLE_GENAI_API_KEY
AI_MODULES_ENDPOINT=https://ai.kitchenxpert.com

# =============================================================================
# AWS S3 [REQUIRED if using file uploads]
# =============================================================================
# SECURITY: Use IAM roles when possible instead of access keys
# SECURITY: Restrict bucket access with proper policies
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY
AWS_S3_BUCKET=kitchenxpert-prod-uploads

# =============================================================================
# FEATURE FLAGS [OPTIONAL]
# =============================================================================
FEATURE_AI_ENABLED=true
FEATURE_3D_ENABLED=true
FEATURE_PARTNERS_ENABLED=true

# =============================================================================
# ANALYTICS [OPTIONAL]
# =============================================================================
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
MIXPANEL_TOKEN=YOUR_MIXPANEL_TOKEN

# =============================================================================
# CATALOG PROVIDERS [OPTIONAL]
# =============================================================================
IKEA_API_ENDPOINT=https://api.ikea.com/v1
IKEA_API_KEY=YOUR_IKEA_API_KEY
LEROY_MERLIN_API_ENDPOINT=https://api.leroymerlin.fr/v1
LEROY_MERLIN_API_KEY=YOUR_LEROY_MERLIN_API_KEY
CASTORAMA_API_ENDPOINT=https://api.castorama.fr/v1
CASTORAMA_API_KEY=YOUR_CASTORAMA_API_KEY
BOSCH_API_ENDPOINT=https://api.bosch-home.com/v1
BOSCH_API_KEY=YOUR_BOSCH_API_KEY


# =============================================================================
# PRODUCTION CHECKLIST
# =============================================================================
# Before deploying to production, ensure:
#
# [ ] All CHANGE_THIS and YOUR_ placeholders are replaced with real values
# [ ] JWT secrets are at least 64 characters and randomly generated
# [ ] Database password is strong and unique
# [ ] SSL/TLS is enabled for database connections
# [ ] Redis authentication is configured
# [ ] CORS origins are restricted to your domains only
# [ ] Rate limiting is enabled
# [ ] Sentry DSN is configured for error tracking
# [ ] All API keys are production keys (not test/sandbox)
# [ ] Environment file is NOT committed to version control
# [ ] Secrets are stored securely (e.g., AWS Secrets Manager, Vault)
# =============================================================================
