# =============================================================================
# KITCHENXPERT ‚Äî PRODUCTION ENVIRONMENT TEMPLATE  (UE / RGPD)
# -----------------------------------------------------------------------------
# Copy this file to `.env.production` (NEVER commit it) and fill every value
# marked CHANGE_ME. Generate strong secrets with `scripts/generate-secrets.sh`.
# Validate the final file with    `bash scripts/preflight-check.sh`.
#
# Legend per variable:
#   FORMAT      ‚Äî expected shape / regex / length
#   SOURCE      ‚Äî where to obtain the value (provider console, CLI, etc.)
#   CRITICALITY ‚Äî REQUIRED  : refuse to boot without it
#                 RECOMMENDED: prod runs but a feature degrades
#                 OPTIONAL   : safe defaults exist
#   ROTATION    ‚Äî recommended cycle. CRITICAL keys rotate every 90 days.
#
# All providers below are **EU-resident** to satisfy RGPD data-locality
# requirements. Replace only with another EU provider unless you are sure
# you can sign Standard Contractual Clauses (SCC 2021/914) for the transfer.
# =============================================================================


# =============================================================================
# 1. RUNTIME                                                          REQUIRED
# =============================================================================
NODE_ENV=production
PORT=4000
HOST=0.0.0.0
APP_NAME=KitchenXpert
APP_URL=https://kitchenxpert.com
API_URL=https://api.kitchenxpert.com
TRUST_PROXY=1
# FORMAT      ‚Äî boolean-ish int. `1` = trust the first reverse proxy hop
#               (Nginx/Traefik/Cloudflare). MUST be set when the app sits
#               behind a load balancer; otherwise express-rate-limit and
#               req.ip will see the proxy IP and IPv4 limits will collapse
#               to one shared bucket.
# CRITICALITY ‚Äî REQUIRED in production deployments behind a reverse proxy.


# =============================================================================
# 2. DATABASE ‚Äî PostgreSQL  (managed UE)                              REQUIRED
# =============================================================================
# Recommended providers (EU-only):
#   - OVHcloud Public Cloud Databases (Gravelines / Strasbourg)
#   - Scaleway Managed Database for PostgreSQL (Paris / Amsterdam)
#   - Clever Cloud PostgreSQL (Paris)
DATABASE_URL=postgresql://kx_app:CHANGE_ME_DB_PASSWORD@db-xxxxxxxx.eu-west-par.database.cloud.ovh.net:20184/kitchenxpert?sslmode=require
# FORMAT      ‚Äî postgresql://USER:PASS@HOST:PORT/DB?sslmode=require
# SOURCE      ‚Äî OVH console ¬ª Public Cloud ¬ª Databases ¬ª <instance> ¬ª Connection
# CRITICALITY ‚Äî REQUIRED. Refuses to start if missing. SSL is mandatory.
# ROTATION    ‚Äî every 90 days; the app reads the URL at startup.

# --- Discrete DB_* vars ‚Äî REQUIRED IN PROD (native pg pool) -----------------
# The backend runs TWO Postgres clients: Prisma (reads DATABASE_URL above) AND
# a native `pg` Pool (packages/backend/src/database/connection.ts) that reads
# these discrete vars from app-config.ts. The pool connects at boot (SELECT
# NOW() with retry); if these are unset it falls back to localhost/postgres
# defaults ‚Üí connection fails ‚Üí process exits. DATABASE_URL alone is NOT
# enough. Mirror the SAME database as DATABASE_URL above.
DB_HOST=db-xxxxxxxx.eu-west-par.database.cloud.ovh.net
DB_PORT=20184
DB_USER=kx_app
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_NAME=kitchenxpert
DB_SSL=true
# FORMAT      ‚Äî discrete components matching DATABASE_URL. DB_SSL=true forces
#               TLS on the native pg pool (managed UE Postgres require it).
# CRITICALITY ‚Äî REQUIRED IN PROD (native pg pool boots on these).

DB_POOL_MIN=2
DB_POOL_MAX=10
# FORMAT      ‚Äî int. Prisma per-instance pool. Multiply by container count;
#               total connections must stay below your provider plan limit
#               (OVH Essential = 100, Scaleway DB-DEV = 75).


# =============================================================================
# 3. REDIS  (managed UE)                                           RECOMMENDED
# =============================================================================
# Recommended providers:
#   - Upstash Redis EU regions (eu-west-1 Ireland, eu-central-1 Frankfurt)
#   - Scaleway Managed Redis (Paris)
#   - Redis Enterprise Cloud Frankfurt
REDIS_URL=rediss://default:CHANGE_ME_REDIS_TOKEN@eu-west-1-1.aws.upstash.io:6379
# FORMAT      ‚Äî `rediss://` (TLS) preferred. Plain `redis://` only on a
#               private network. Upstash issues a `default` user + token.
# SOURCE      ‚Äî Upstash console ¬ª Database ¬ª Endpoint
# CRITICALITY ‚Äî RECOMMENDED. Used for token-blacklist, caching, rate-limit
#               store and job queues. The backend DEGRADES GRACEFULLY without
#               it ‚Äî a circuit breaker in redis-client.ts lets the server boot
#               and serve /health even if Redis is down (those features are
#               reduced, not fatal). Strongly recommended for prod all the same.
# ROTATION    ‚Äî every 90 days; rotate via Upstash REST API or console.

REDIS_TLS_REJECT_UNAUTHORIZED=true
# FORMAT      ‚Äî boolean. Force certificate verification on the rediss://
#               handshake. Only set to `false` when targeting localhost
#               for debugging ‚Äî never in production.


# =============================================================================
# 4. JWT SIGNING KEYS                                CRITICAL ‚Äî REQUIRED
# =============================================================================
# Generate with:  bash scripts/generate-secrets.sh
# Each secret MUST be at least 64 bytes of cryptographic randomness.
# A leaked secret = total session takeover. Rotate every 90 days; both
# secrets must be rotated independently with a 24h grace period.
JWT_ACCESS_SECRET=CHANGE_ME_64_BYTE_BASE64
# FORMAT      ‚Äî base64 string, ‚â• 64 bytes decoded
# SOURCE      ‚Äî `openssl rand -base64 64`
# ROTATION    ‚Äî every 90 days. Rotation invalidates all access tokens
#               (15-minute window). Schedule outside peak hours.

JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_64_BYTE_BASE64
# FORMAT      ‚Äî base64 string, ‚â• 64 bytes decoded. MUST differ from
#               JWT_ACCESS_SECRET (compromise-isolation).
# ROTATION    ‚Äî every 90 days, ideally offset by 45 days from access key
#               so both never lapse simultaneously.

JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d


# =============================================================================
# 5. SYMMETRIC ENCRYPTION KEY (AES-256-GCM)         CRITICAL ‚Äî REQUIRED
# =============================================================================
# Used to encrypt third-party API keys stored at rest in Postgres
# (provider tokens, partner secrets). DO NOT lose this key ‚Äî encrypted
# rows become permanently unreadable without it. Back it up in your
# password manager AND your team's vault.
DATA_ENCRYPTION_KEY=CHANGE_ME_HEX_32_BYTES
# FORMAT      ‚Äî hex string, exactly 32 bytes (64 hex chars)
# SOURCE      ‚Äî `openssl rand -hex 32`
# ROTATION    ‚Äî only via deliberate re-encrypt migration. Never overwrite
#               without re-encrypting all dependent rows first.


# =============================================================================
# 6. CORS                                                              REQUIRED
# =============================================================================
# Strict origin allow-list. Wildcards are rejected at boot.
CORS_ORIGINS=https://kitchenxpert.com,https://www.kitchenxpert.com,https://app.kitchenxpert.com
# FORMAT      ‚Äî comma-separated origins (scheme + host + optional port).
#               No trailing slash. No `*`.
# CRITICALITY ‚Äî REQUIRED. CORS misconfig is the #1 source of frontend
#               outages on a fresh deploy.


# =============================================================================
# 7. SECURITY KNOBS                                                    REQUIRED
# =============================================================================
BCRYPT_ROUNDS=12
# FORMAT      ‚Äî int between 10 and 15. 12 = ~250 ms/hash on a modern CPU.
#               Increase to 14 if you serve <50 logins/min.

ENABLE_RATE_LIMIT=true
ENABLE_HELMET=true
ENABLE_CORS=true

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
# FORMAT      ‚Äî generic baseline. Per-route limits live in
#               `packages/backend/src/api/middleware/rate-limit-middleware.ts`.

INTERNAL_API_KEY=CHANGE_ME_64_BYTE_BASE64
# FORMAT      ‚Äî base64 ‚â• 32 bytes. Trusted internal services pass this in
#               `X-Internal-Key` to bypass user-facing rate limits.
# SOURCE      ‚Äî `openssl rand -base64 48`
# CRITICALITY ‚Äî REQUIRED if you run cron workers or webhook bridges that
#               call your own API. Rotate every 90 days.


# =============================================================================
# 8. EMAIL ‚Äî Transactional (UE)                                        REQUIRED
# =============================================================================
# Recommended providers (UE-resident SMTP):
#   - Brevo (ex-Sendinblue, FR) ‚Äî free tier 300/day
#   - Mailjet (FR) ‚Äî free tier 200/day
#   - SendGrid EU (US-owned, EU residency, requires Pro plan + DPA)
MAIL_PROVIDER=brevo
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=CHANGE_ME_BREVO_LOGIN
SMTP_PASS=CHANGE_ME_BREVO_SMTP_KEY
# FORMAT      ‚Äî Brevo: SMTP_USER is your account email,
#               SMTP_PASS is the SMTP key from
#               https://app.brevo.com/settings/keys/smtp
# CRITICALITY ‚Äî REQUIRED for email verification, password reset, RGPD
#               data-export delivery, payment receipts.
# ROTATION    ‚Äî every 180 days.

MAIL_FROM=noreply@kitchenxpert.com
EMAIL_FROM=noreply@kitchenxpert.com
# Both names exist for historical reasons; keep them identical.
# Configure SPF + DKIM + DMARC at your registrar before first send.


# =============================================================================
# 9. OBJECT STORAGE ‚Äî S3-compatible (UE)                               REQUIRED
# =============================================================================
# Recommended providers (S3-compatible, UE):
#   - Scaleway Object Storage (Paris / Amsterdam)
#   - OVHcloud Object Storage (Gravelines / Strasbourg)
S3_ENDPOINT=https://s3.fr-par.scw.cloud
S3_REGION=fr-par
S3_BUCKET=kitchenxpert-prod-uploads
S3_ACCESS_KEY_ID=CHANGE_ME_SCW_ACCESS_KEY
S3_SECRET_ACCESS_KEY=CHANGE_ME_SCW_SECRET_KEY
S3_PUBLIC_URL=https://kitchenxpert-prod-uploads.s3.fr-par.scw.cloud
# FORMAT      ‚Äî Scaleway endpoint + region pair. Bucket must be created
#               with public-read disabled at the bucket level; ACLs are
#               set per object by the upload pipeline.
# SOURCE      ‚Äî Scaleway console ¬ª Identity ¬ª API Keys
# ROTATION    ‚Äî every 90 days. Scaleway supports key duo-rotation.

# AWS-compatible aliases kept for backwards compatibility with the
# existing aws-sdk client code.
AWS_REGION=${S3_REGION}
AWS_ACCESS_KEY_ID=${S3_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${S3_SECRET_ACCESS_KEY}
AWS_S3_BUCKET=${S3_BUCKET}
AWS_S3_ENDPOINT=${S3_ENDPOINT}


# =============================================================================
# 10. PAYMENTS ‚Äî Stripe (live)                                         REQUIRED
# =============================================================================
# DSP2/SCA-compliant. Stripe is Irish-resident for EU customers (Stripe
# Payments Europe Ltd). Use `pk_live_` / `sk_live_` keys ONLY in prod.
STRIPE_PUBLIC_KEY=pk_live_CHANGE_ME
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
# FORMAT      ‚Äî Stripe-issued. The PUBLIC key is exposed to the browser;
#               the SECRET key MUST never reach the frontend bundle.
# SOURCE      ‚Äî https://dashboard.stripe.com/apikeys (toggle "Live mode")
# ROTATION    ‚Äî when staff with access leaves, or annually as hygiene.

STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
# FORMAT      ‚Äî Stripe-issued, starts with `whsec_`.
# SOURCE      ‚Äî Dashboard ¬ª Developers ¬ª Webhooks ¬ª <endpoint> ¬ª Signing secret
# CRITICALITY ‚Äî REQUIRED. Without this the backend cannot verify webhook
#               authenticity ‚Üí all payment confirmations are rejected.

STRIPE_PRICE_PREMIUM=price_CHANGE_ME
STRIPE_PRICE_STUDIO=price_CHANGE_ME
# FORMAT      ‚Äî Stripe Price IDs (one per pricing tier defined in
#               packages/frontend/src/config/legal.ts pricingTiers).


# =============================================================================
# 11. AI PROVIDERS                                              RECOMMENDED
# =============================================================================
# These keys gate the AI assistant + image generation. The app degrades
# gracefully (feature flag off) if absent, but production launch should
# include them.

ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
# FORMAT      ‚Äî Anthropic-issued, starts with `sk-ant-`.
# SOURCE      ‚Äî https://console.anthropic.com/settings/keys
# CRITICALITY ‚Äî RECOMMENDED. Disables the conversational assistant if
#               unset. RGPD: requires a signed DPA; non-EU transfer is
#               covered by SCC 2021/914 (declared in Privacy page).
# ROTATION    ‚Äî every 180 days.

GOOGLE_GENAI_API_KEY=CHANGE_ME
# FORMAT      ‚Äî Google API key string.
# SOURCE      ‚Äî https://aistudio.google.com/app/apikey
# CRITICALITY ‚Äî RECOMMENDED. Disables photorealistic kitchen image
#               generation if unset.

AI_MODULES_ENDPOINT=https://ai.kitchenxpert.com
# Optional self-hosted AI inference cluster URL.


# =============================================================================
# 12. CATALOG PROVIDERS (B2B partner APIs)                       OPTIONAL
# =============================================================================
# All four are optional ‚Äî the catalog falls back to the local mirror.
IKEA_API_ENDPOINT=https://api.ikea.com/v1
IKEA_API_KEY=CHANGE_ME

LEROY_MERLIN_API_ENDPOINT=https://api.leroymerlin.fr/v1
LEROY_MERLIN_API_KEY=CHANGE_ME

CASTORAMA_API_ENDPOINT=https://api.castorama.fr/v1
CASTORAMA_API_KEY=CHANGE_ME

BOSCH_API_ENDPOINT=https://api.bosch-home.com/v1
BOSCH_API_KEY=CHANGE_ME

SCHMIDT_API_ENDPOINT=https://api.schmidt-groupe.com/v1
SCHMIDT_API_KEY=CHANGE_ME


# =============================================================================
# 13. OBSERVABILITY                                            RECOMMENDED
# =============================================================================
LOG_LEVEL=info
# FORMAT ‚Äî `error` | `warn` | `info` | `http` | `debug`. `info` keeps
#          access logs but suppresses verbose query traces.

SENTRY_DSN=https://CHANGE_ME@oXXXX.ingest.sentry.io/CHANGE_ME
# FORMAT      ‚Äî Sentry-issued DSN URL.
# SOURCE      ‚Äî Sentry ¬ª Settings ¬ª Projects ¬ª <project> ¬ª Client Keys (DSN)
# CRITICALITY ‚Äî RECOMMENDED. Without it, production errors only land in
#               container logs (no stack traces, no alerting).
# ROTATION    ‚Äî only when project is reset or compromised.

SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.10
# FORMAT ‚Äî float 0..1. 10% transaction sampling balances cost vs signal.

SENTRY_SEND_DEFAULT_PII=false
# REQUIRED ‚Äî must remain `false` to comply with RGPD purpose limitation.


# =============================================================================
# 14. ANALYTICS  (cookieless, RGPD-friendly)                   OPTIONAL
# =============================================================================
# Plausible self-hosted on EU infra is the default. Avoid Google Analytics
# unless you implement a fully blocking consent gate.
PLAUSIBLE_DOMAIN=kitchenxpert.com
PLAUSIBLE_API_HOST=https://plausible.kitchenxpert.com
# FORMAT ‚Äî your Plausible instance hostname. The frontend script tag
#          reads these via Vite env at build time.


# =============================================================================
# 15. FEATURE FLAGS                                                     OPTIONAL
# =============================================================================
FEATURE_AI_ENABLED=true
FEATURE_3D_ENABLED=true
FEATURE_PARTNERS_ENABLED=true
FEATURE_AR_VR_ENABLED=true
# Flipping AR_VR off relaxes the camera/microphone Permissions-Policy so
# advertising trackers cannot abuse the relaxed grant.


# =============================================================================
# 16. FRONTEND BUILD-TIME (Vite)                                       REQUIRED
# =============================================================================
# These are baked into the static bundle at `vite build` time and are
# therefore PUBLIC. Never put secrets here.
VITE_API_URL=https://api.kitchenxpert.com
VITE_WS_URL=wss://api.kitchenxpert.com
VITE_3D_ENGINE_URL=https://3d.kitchenxpert.com
VITE_STRIPE_PUBLIC_KEY=${STRIPE_PUBLIC_KEY}
VITE_PLAUSIBLE_DOMAIN=${PLAUSIBLE_DOMAIN}
VITE_SENTRY_DSN=${SENTRY_DSN}


# =============================================================================
# PRODUCTION READINESS CHECKLIST
# =============================================================================
#  [ ] All CHANGE_ME placeholders are replaced
#  [ ] JWT secrets are ‚â• 64 bytes and unique to this environment
#  [ ] DATA_ENCRYPTION_KEY is backed up in BOTH password manager and vault
#  [ ] DATABASE_URL uses sslmode=require
#  [ ] REDIS_URL uses rediss:// (TLS)
#  [ ] CORS_ORIGINS contains exact production hostnames (no wildcards)
#  [ ] STRIPE_*  keys start with `pk_live_` / `sk_live_` / `whsec_`
#  [ ] SPF + DKIM + DMARC verified for the MAIL_FROM domain
#  [ ] SENTRY_DSN configured and a test error has been captured
#  [ ] Run `bash scripts/preflight-check.sh` and every check is green
#  [ ] `.env.production` is in your secret store (not in the repo)
# =============================================================================
