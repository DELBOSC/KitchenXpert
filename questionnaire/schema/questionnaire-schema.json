{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kitchenxpert.com/schemas/questionnaire.json",
  "title": "KitchenXpert Questionnaire Schema",
  "description": "Schema for the kitchen design questionnaire system",
  "type": "object",
  "required": ["id", "version", "sections", "metadata"],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique questionnaire identifier"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the questionnaire"
    },
    "metadata": {
      "type": "object",
      "required": ["title", "description", "estimatedTime", "languages"],
      "properties": {
        "title": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Localized titles"
        },
        "description": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Localized descriptions"
        },
        "estimatedTime": {
          "type": "integer",
          "minimum": 1,
          "description": "Estimated completion time in minutes"
        },
        "languages": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z]{2}(-[A-Z]{2})?$" },
          "minItems": 1,
          "description": "Supported language codes"
        }
      }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/section" }
    },
    "scoring": {
      "type": "object",
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": ["weighted", "simple", "ml-based"]
        },
        "weights": {
          "type": "object",
          "additionalProperties": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    }
  },
  "definitions": {
    "section": {
      "type": "object",
      "required": ["id", "title", "questions"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "title": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "description": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "icon": {
          "type": "string"
        },
        "order": {
          "type": "integer",
          "minimum": 0
        },
        "required": {
          "type": "boolean",
          "default": true
        },
        "conditional": {
          "$ref": "#/definitions/condition"
        },
        "questions": {
          "type": "array",
          "items": { "$ref": "#/definitions/question" }
        }
      }
    },
    "question": {
      "type": "object",
      "required": ["id", "type", "label"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "type": {
          "type": "string",
          "enum": [
            "single-choice",
            "multi-choice",
            "text",
            "number",
            "range",
            "slider",
            "image-choice",
            "dimension",
            "date",
            "rating",
            "boolean",
            "color-picker",
            "file-upload"
          ]
        },
        "label": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "description": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "placeholder": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "required": {
          "type": "boolean",
          "default": false
        },
        "options": {
          "type": "array",
          "items": { "$ref": "#/definitions/option" }
        },
        "validation": {
          "$ref": "#/definitions/validation"
        },
        "conditional": {
          "$ref": "#/definitions/condition"
        },
        "scoring": {
          "$ref": "#/definitions/questionScoring"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "option": {
      "type": "object",
      "required": ["value", "label"],
      "properties": {
        "value": {
          "type": ["string", "number", "boolean"]
        },
        "label": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "description": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "image": {
          "type": "string",
          "format": "uri"
        },
        "icon": {
          "type": "string"
        },
        "score": {
          "type": "number"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "validation": {
      "type": "object",
      "properties": {
        "min": { "type": "number" },
        "max": { "type": "number" },
        "minLength": { "type": "integer", "minimum": 0 },
        "maxLength": { "type": "integer", "minimum": 1 },
        "pattern": { "type": "string" },
        "patternMessage": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "custom": { "type": "string" }
      }
    },
    "condition": {
      "type": "object",
      "properties": {
        "operator": {
          "type": "string",
          "enum": ["and", "or", "not"]
        },
        "conditions": {
          "type": "array",
          "items": {
            "oneOf": [
              { "$ref": "#/definitions/condition" },
              { "$ref": "#/definitions/simpleCondition" }
            ]
          }
        }
      }
    },
    "simpleCondition": {
      "type": "object",
      "required": ["questionId", "operator", "value"],
      "properties": {
        "questionId": { "type": "string" },
        "operator": {
          "type": "string",
          "enum": [
            "equals",
            "not-equals",
            "contains",
            "not-contains",
            "greater-than",
            "less-than",
            "in",
            "not-in"
          ]
        },
        "value": {
          "type": ["string", "number", "boolean", "array"]
        }
      }
    },
    "questionScoring": {
      "type": "object",
      "properties": {
        "weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "default": 1
        },
        "categories": {
          "type": "array",
          "items": { "type": "string" }
        },
        "impactAreas": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "budget",
              "style",
              "functionality",
              "space",
              "technology",
              "sustainability",
              "maintenance"
            ]
          }
        }
      }
    }
  }
}
