{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kitchenxpert.com/schemas/questionnaire-response.json",
  "title": "KitchenXpert Questionnaire Response Schema",
  "description": "Schema for questionnaire responses and user submissions",
  "type": "object",
  "required": [
    "id",
    "questionnaireId",
    "userId",
    "responses",
    "status",
    "timestamps"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique response session identifier"
    },
    "questionnaireId": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the questionnaire version"
    },
    "questionnaireVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "userId": {
      "type": "string",
      "description": "User who submitted the response"
    },
    "projectId": {
      "type": "string",
      "format": "uuid",
      "description": "Associated kitchen project ID"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "in-progress", "completed", "abandoned", "expired"],
      "default": "draft"
    },
    "progress": {
      "type": "object",
      "properties": {
        "currentSection": { "type": "string" },
        "currentQuestion": { "type": "string" },
        "completedSections": { "type": "array", "items": { "type": "string" } },
        "percentComplete": { "type": "number", "minimum": 0, "maximum": 100 },
        "answeredQuestions": { "type": "integer", "minimum": 0 },
        "totalQuestions": { "type": "integer", "minimum": 0 }
      }
    },
    "responses": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/sectionResponse" }
    },
    "scores": { "$ref": "#/definitions/scoringResult" },
    "analysis": { "$ref": "#/definitions/analysisResult" },
    "recommendations": {
      "type": "array",
      "items": { "$ref": "#/definitions/recommendation" }
    },
    "timestamps": {
      "type": "object",
      "required": ["createdAt"],
      "properties": {
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "lastActivityAt": { "type": "string", "format": "date-time" }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "language": { "type": "string", "pattern": "^[a-z]{2}(-[A-Z]{2})?$" },
        "device": { "type": "string", "enum": ["desktop", "tablet", "mobile"] },
        "userAgent": { "type": "string" },
        "sessionDuration": {
          "type": "integer",
          "description": "Total time spent in seconds"
        },
        "revisits": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "definitions": {
    "sectionResponse": {
      "type": "object",
      "properties": {
        "completed": { "type": "boolean", "default": false },
        "startedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "answers": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/answer" }
        }
      }
    },
    "answer": {
      "type": "object",
      "required": ["questionId", "value"],
      "properties": {
        "questionId": { "type": "string" },
        "value": {
          "type": ["string", "number", "boolean", "array", "object", "null"]
        },
        "displayValue": { "type": "string" },
        "unit": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "skipped": { "type": "boolean", "default": false },
        "skipReason": { "type": "string" },
        "answeredAt": { "type": "string", "format": "date-time" },
        "timeSpent": { "type": "integer" },
        "revisions": { "type": "integer", "minimum": 0 }
      }
    },
    "scoringResult": {
      "type": "object",
      "properties": {
        "overall": { "type": "number", "minimum": 0, "maximum": 100 },
        "categories": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "score": { "type": "number", "minimum": 0, "maximum": 100 },
              "weight": { "type": "number", "minimum": 0, "maximum": 1 },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          }
        },
        "budgetScore": { "type": "number" },
        "styleScore": { "type": "number" },
        "functionalityScore": { "type": "number" },
        "spaceScore": { "type": "number" },
        "technologyScore": { "type": "number" },
        "sustainabilityScore": { "type": "number" }
      }
    },
    "analysisResult": {
      "type": "object",
      "properties": {
        "userProfile": {
          "type": "object",
          "properties": {
            "householdType": { "type": "string" },
            "cookingLevel": {
              "type": "string",
              "enum": ["beginner", "intermediate", "advanced", "professional"]
            },
            "lifestylePattern": { "type": "string" },
            "priorityAreas": { "type": "array", "items": { "type": "string" } }
          }
        },
        "budgetAnalysis": {
          "type": "object",
          "properties": {
            "totalBudget": { "type": "number" },
            "currency": { "type": "string" },
            "flexibility": {
              "type": "string",
              "enum": ["strict", "moderate", "flexible"]
            },
            "allocationSuggestion": {
              "type": "object",
              "properties": {
                "cabinets": { "type": "number" },
                "appliances": { "type": "number" },
                "countertops": { "type": "number" },
                "flooring": { "type": "number" },
                "lighting": { "type": "number" },
                "installation": { "type": "number" },
                "contingency": { "type": "number" }
              }
            }
          }
        },
        "spatialAnalysis": {
          "type": "object",
          "properties": {
            "totalArea": { "type": "number" },
            "areaUnit": { "type": "string", "enum": ["sqft", "sqm"] },
            "layoutType": {
              "type": "string",
              "enum": [
                "galley",
                "l-shaped",
                "u-shaped",
                "island",
                "peninsula",
                "one-wall",
                "open-plan"
              ]
            },
            "workTriangle": {
              "type": "object",
              "properties": {
                "optimal": { "type": "boolean" },
                "suggestions": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            },
            "storageCapacity": {
              "type": "string",
              "enum": ["minimal", "standard", "extended", "maximum"]
            }
          }
        },
        "styleProfile": {
          "type": "object",
          "properties": {
            "primaryStyle": { "type": "string" },
            "secondaryStyles": {
              "type": "array",
              "items": { "type": "string" }
            },
            "colorPalette": { "type": "array", "items": { "type": "string" } },
            "materialPreferences": {
              "type": "array",
              "items": { "type": "string" }
            },
            "finishPreferences": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "functionalNeeds": {
          "type": "object",
          "properties": {
            "cookingFrequency": { "type": "string" },
            "mealTypes": { "type": "array", "items": { "type": "string" } },
            "specialRequirements": {
              "type": "array",
              "items": { "type": "string" }
            },
            "appliancePriorities": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "recommendation": {
      "type": "object",
      "required": ["id", "type", "title", "priority"],
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": [
            "layout",
            "appliance",
            "material",
            "style",
            "storage",
            "lighting",
            "technology",
            "sustainability"
          ]
        },
        "title": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "description": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "priority": {
          "type": "string",
          "enum": ["essential", "recommended", "optional", "luxury"]
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "estimatedCost": {
          "type": "object",
          "properties": {
            "min": { "type": "number" },
            "max": { "type": "number" },
            "currency": { "type": "string" }
          }
        },
        "relatedProducts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "matchScore": { "type": "number" }
            }
          }
        },
        "basedOn": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
