{
  "sectionId": "spatial-constraints",
  "version": "1.0.0",
  "rules": [
    {
      "id": "small-kitchen-layout-warning",
      "condition": {
        "questionId": "kitchen-size",
        "operator": "equals",
        "value": "small"
      },
      "action": {
        "type": "show-message",
        "message": {
          "en": "For smaller kitchens, one-wall or galley layouts work best.",
          "fr": "Pour les petites cuisines, les dispositions linéaires ou couloir fonctionnent mieux."
        },
        "severity": "info"
      }
    },
    {
      "id": "island-space-check",
      "condition": {
        "operator": "and",
        "conditions": [
          {
            "questionId": "kitchen-size",
            "operator": "in",
            "value": ["small", "medium"]
          },
          {
            "questionId": "island-preference",
            "operator": "in",
            "value": ["yes-large", "yes-small"]
          }
        ]
      },
      "action": {
        "type": "show-message",
        "message": {
          "en": "Your kitchen may be too small for an island. Consider a peninsula.",
          "fr": "Votre cuisine peut être trop petite pour un îlot. Considérez une péninsule."
        },
        "severity": "warning"
      }
    }
  ],
  "sectionFlow": {
    "defaultOrder": [
      "kitchen-size",
      "exact-dimensions",
      "ceiling-height",
      "current-layout",
      "desired-layout",
      "island-preference",
      "structural-constraints",
      "open-concept",
      "storage-needs",
      "pantry-preference"
    ],
    "adaptiveFlow": true,
    "allowSkip": false,
    "allowBack": true
  },
  "completion": {
    "requiredQuestions": [
      "kitchen-size",
      "ceiling-height",
      "current-layout",
      "desired-layout",
      "island-preference",
      "structural-constraints",
      "open-concept",
      "storage-needs",
      "pantry-preference"
    ],
    "minimumAnswered": 9
  }
}
