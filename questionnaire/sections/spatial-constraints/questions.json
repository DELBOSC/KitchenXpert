      "type": "single-choice",
      "required": true,
      "label": {
        "en": "How would you describe your storage needs?",
        "fr": "Comment décririez-vous vos besoins de rangement ?"
      },
      "options": [
        {
          "value": "minimal",
          "label": { "en": "Minimal - I keep things simple", "fr": "Minimal - Je garde les choses simples" },
          "tags": ["minimalist"]
        },
        {
          "value": "average",
          "label": { "en": "Average - Standard kitchen items", "fr": "Moyen - Articles de cuisine standard" },
          "tags": ["standard-storage"]
        },
        {
          "value": "above-average",
          "label": { "en": "Above average - I have lots of gadgets", "fr": "Au-dessus de la moyenne - J'ai beaucoup d'ustensiles" },
          "tags": ["extra-storage", "organization"]
        },
        {
          "value": "maximum",
          "label": { "en": "Maximum - Need all the storage possible", "fr": "Maximum - Besoin de tout le rangement possible" },
