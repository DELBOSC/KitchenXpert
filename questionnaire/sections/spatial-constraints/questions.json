{
  "sectionId": "spatial-constraints",
  "version": "1.0.0",
  "metadata": {
    "title": {
      "en": "Kitchen Space & Layout",
      "fr": "Espace et disposition de la cuisine"
    },
    "description": {
      "en": "Help us understand your kitchen space to optimize the design",
      "fr": "Aidez-nous à comprendre votre espace cuisine pour optimiser la conception"
    },
    "icon": "layout",
    "estimatedTime": 5
  },
  "questions": [
    {
      "id": "kitchen-size",
      "type": "single-choice",
      "required": true,
      "label": {
        "en": "What is the approximate size of your kitchen?",
        "fr": "Quelle est la taille approximative de votre cuisine ?"
      },
      "options": [
        {
          "value": "small",
          "label": { "en": "Small (under 100 sq ft / 9 m²)", "fr": "Petite (moins de 9 m²)" },
          "tags": ["compact", "efficiency-focused"]
        },
        {
          "value": "medium",
          "label": { "en": "Medium (100-150 sq ft / 9-14 m²)", "fr": "Moyenne (9-14 m²)" },
          "tags": ["standard", "flexible"]
        },
        {
          "value": "large",
          "label": { "en": "Large (150-250 sq ft / 14-23 m²)", "fr": "Grande (14-23 m²)" },
          "tags": ["spacious", "island-possible"]
        },
        {
          "value": "very-large",
          "label": { "en": "Very Large (over 250 sq ft / 23 m²)", "fr": "Très grande (plus de 23 m²)" },
          "tags": ["luxury-space", "multiple-zones"]
        }
      ],
      "scoring": {
        "weight": 4,
        "categories": ["space-category"],
        "impactAreas": ["space"]
      }
    },
    {
      "id": "exact-dimensions",
      "type": "dimension",
      "required": false,
      "label": {
        "en": "Enter your kitchen dimensions (if known)",
        "fr": "Entrez les dimensions de votre cuisine (si connues)"
      },
      "description": {
        "en": "Provide length and width for more accurate recommendations",
        "fr": "Fournissez la longueur et la largeur pour des recommandations plus précises"
      },
      "metadata": {
        "units": ["ft", "m"],
        "defaultUnit": "ft",
        "fields": ["length", "width"]
      },
      "validation": {
        "min": 4,
        "max": 100
      },
      "scoring": {
        "weight": 3,
        "categories": ["precise-dimensions"],
        "impactAreas": ["space"]
      }
    },
    {
      "id": "ceiling-height",
      "type": "single-choice",
      "required": true,
      "label": {
        "en": "What is your ceiling height?",
        "fr": "Quelle est la hauteur de votre plafond ?"
      },
      "options": [
        {
          "value": "standard",
          "label": { "en": "Standard (8 ft / 2.4 m)", "fr": "Standard (2,4 m)" },
          "tags": ["standard-cabinets"]
        },
        {
          "value": "tall",
          "label": { "en": "Tall (9-10 ft / 2.7-3 m)", "fr": "Haut (2,7-3 m)" },
          "tags": ["extended-cabinets", "stacking-possible"]
        },
        {
          "value": "very-tall",
          "label": { "en": "Very Tall (over 10 ft / 3 m)", "fr": "Très haut (plus de 3 m)" },
          "tags": ["custom-height", "dramatic-design"]
        },
        {
          "value": "vaulted",
          "label": { "en": "Vaulted/Sloped", "fr": "Cathédrale/En pente" },
          "tags": ["variable-height", "custom-solutions"]
        }
      ],
      "scoring": {
        "weight": 2,
        "categories": ["vertical-space"],
        "impactAreas": ["space", "style"]
      }
    },
    {
      "id": "current-layout",
      "type": "image-choice",
      "required": true,
      "label": {
        "en": "What is your current kitchen layout?",
        "fr": "Quelle est la disposition actuelle de votre cuisine ?"
      },
      "options": [
        {
          "value": "one-wall",
          "label": { "en": "One-Wall (Galley)", "fr": "Linéaire" },
          "image": "/images/layouts/one-wall.svg",
          "description": { "en": "All along one wall", "fr": "Tout le long d'un mur" }
        },
        {
          "value": "galley",
          "label": { "en": "Galley (Corridor)", "fr": "Couloir" },
          "image": "/images/layouts/galley.svg",
          "description": { "en": "Two parallel walls", "fr": "Deux murs parallèles" }
        },
        {
          "value": "l-shaped",
          "label": { "en": "L-Shaped", "fr": "En L" },
          "image": "/images/layouts/l-shaped.svg",
          "description": { "en": "Two perpendicular walls", "fr": "Deux murs perpendiculaires" }
        },
        {
          "value": "u-shaped",
          "label": { "en": "U-Shaped", "fr": "En U" },
          "image": "/images/layouts/u-shaped.svg",
          "description": { "en": "Three walls", "fr": "Trois murs" }
        },
        {
          "value": "peninsula",
          "label": { "en": "Peninsula", "fr": "Péninsule" },
          "image": "/images/layouts/peninsula.svg",
          "description": { "en": "L or U with attached counter", "fr": "L ou U avec comptoir attaché" }
        },
        {
          "value": "island",
          "label": { "en": "Island", "fr": "Îlot" },
          "image": "/images/layouts/island.svg",
          "description": { "en": "Freestanding center piece", "fr": "Élément central indépendant" }
        }
      ],
      "scoring": {
        "weight": 4,
        "categories": ["layout-type"],
        "impactAreas": ["space", "functionality"]
      }
    },
    {
