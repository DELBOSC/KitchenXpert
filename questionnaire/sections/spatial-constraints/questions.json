      "description": {
        "en": "Select all that apply",
        "fr": "Sélectionnez tout ce qui s'applique"
      },
      "options": [
        {
          "value": "load-bearing-wall",
          "label": { "en": "Load-bearing wall that can't be moved", "fr": "Mur porteur qui ne peut pas être déplacé" },
          "tags": ["structural-limit"]
        },
        {
          "value": "window-placement",
          "label": { "en": "Fixed window placement", "fr": "Emplacement fixe des fenêtres" },
          "tags": ["window-constraint"]
        },
        {
          "value": "plumbing-location",
          "label": { "en": "Plumbing in fixed location", "fr": "Plomberie à emplacement fixe" },
          "tags": ["plumbing-limit"]
        },
        {
          "value": "gas-line",
          "label": { "en": "Gas line location", "fr": "Emplacement de la conduite de gaz" },
          "tags": ["gas-constraint"]
        },
        {
          "value": "electrical-panel",
          "label": { "en": "Electrical panel in kitchen", "fr": "Panneau électrique dans la cuisine" },
          "tags": ["electrical-limit"]
        },
        {
          "value": "hvac-ducts",
          "label": { "en": "HVAC ducts/vents", "fr": "Conduits/bouches de ventilation" },
          "tags": ["hvac-constraint"]
        },
        {
          "value": "door-locations",
          "label": { "en": "Door locations can't change", "fr": "Les emplacements des portes ne peuvent pas changer" },
          "tags": ["door-constraint"]
        },
        {
          "value": "none",
          "label": { "en": "No constraints / Can modify anything", "fr": "Pas de contraintes / Peut tout modifier" },
          "tags": ["flexible"]
        }
      ],
      "scoring": {
        "weight": 3,
        "categories": ["constraints"],
        "impactAreas": ["space", "budget"]
      }
    },
    {
      "id": "open-concept",
      "type": "single-choice",
      "required": true,
      "label": {
        "en": "Is your kitchen open to other living spaces?",
        "fr": "Votre cuisine est-elle ouverte sur d'autres espaces de vie ?"
      },
      "options": [
        {
          "value": "fully-open",
          "label": { "en": "Fully open concept", "fr": "Entièrement ouvert" },
          "description": { "en": "Flows into living/dining", "fr": "S'ouvre sur le salon/salle à manger" },
          "tags": ["open-plan", "visibility-important"]
        },
        {
          "value": "partial-open",
          "label": { "en": "Partially open", "fr": "Partiellement ouvert" },
          "description": { "en": "Pass-through or half wall", "fr": "Passe-plat ou demi-mur" },
          "tags": ["semi-open"]
        },
        {
          "value": "closed",
          "label": { "en": "Enclosed/Separate room", "fr": "Fermée/Pièce séparée" },
          "description": { "en": "Traditional enclosed kitchen", "fr": "Cuisine fermée traditionnelle" },
          "tags": ["enclosed", "private"]
        },
        {
          "value": "want-to-open",
          "label": { "en": "Currently closed, want to open up", "fr": "Actuellement fermée, souhaite ouvrir" },
          "tags": ["renovation-required", "structural-change"]
        }
      ],
      "scoring": {
        "weight": 3,
        "categories": ["openness"],
        "impactAreas": ["space", "style", "budget"]
      }
    },
    {
