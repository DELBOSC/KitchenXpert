      "required": true,
      "label": {
        "en": "What layout would you like?",
        "fr": "Quelle disposition souhaitez-vous ?"
      },
      "description": {
        "en": "Select your preferred layout (we'll check if it's feasible)",
        "fr": "Sélectionnez votre disposition préférée (nous vérifierons la faisabilité)"
      },
      "options": [
        {
          "value": "keep-current",
          "label": { "en": "Keep Current Layout", "fr": "Garder la disposition actuelle" },
          "tags": ["no-structural"]
        },
        {
          "value": "one-wall",
          "label": { "en": "One-Wall", "fr": "Linéaire" },
          "image": "/images/layouts/one-wall.svg"
        },
        {
          "value": "galley",
          "label": { "en": "Galley", "fr": "Couloir" },
          "image": "/images/layouts/galley.svg"
        },
        {
          "value": "l-shaped",
          "label": { "en": "L-Shaped", "fr": "En L" },
          "image": "/images/layouts/l-shaped.svg"
        },
        {
          "value": "u-shaped",
          "label": { "en": "U-Shaped", "fr": "En U" },
          "image": "/images/layouts/u-shaped.svg"
        },
        {
          "value": "peninsula",
          "label": { "en": "Peninsula", "fr": "Péninsule" },
          "image": "/images/layouts/peninsula.svg"
        },
        {
          "value": "island",
          "label": { "en": "Island", "fr": "Îlot" },
          "image": "/images/layouts/island.svg"
        }
      ],
      "scoring": {
        "weight": 4,
        "categories": ["desired-layout"],
        "impactAreas": ["space", "functionality", "budget"]
      }
    },
    {
      "id": "island-preference",
      "type": "single-choice",
      "required": true,
      "label": {
        "en": "Do you want a kitchen island?",
        "fr": "Voulez-vous un îlot de cuisine ?"
      },
      "options": [
        {
          "value": "yes-large",
          "label": { "en": "Yes, a large island with seating", "fr": "Oui, un grand îlot avec sièges" },
          "tags": ["large-island", "seating", "prep-space"]
        },
        {
          "value": "yes-small",
          "label": { "en": "Yes, a small/compact island", "fr": "Oui, un petit îlot compact" },
          "tags": ["small-island", "extra-storage"]
        },
        {
          "value": "yes-mobile",
          "label": { "en": "A mobile/rolling island", "fr": "Un îlot mobile/sur roulettes" },
          "tags": ["mobile", "flexible"]
        },
        {
          "value": "peninsula-instead",
          "label": { "en": "Prefer a peninsula", "fr": "Préfère une péninsule" },
          "tags": ["peninsula", "connected"]
        },
        {
          "value": "no",
          "label": { "en": "No island needed", "fr": "Pas d'îlot nécessaire" },
          "tags": ["no-island"]
        }
      ],
      "scoring": {
        "weight": 3,
        "categories": ["island-type"],
        "impactAreas": ["space", "functionality"]
      }
    },
    {
