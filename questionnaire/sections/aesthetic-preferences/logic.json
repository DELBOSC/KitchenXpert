{
  "sectionId": "aesthetic-preferences",
  "version": "1.0.0",
  "rules": [
    {
      "id": "modern-style-suggestions",
      "description": "Suggest compatible elements for modern style",
      "condition": {
        "questionId": "kitchen-style",
        "operator": "equals",
        "value": "modern"
      },
      "action": {
        "type": "highlight-options",
        "targets": [
          { "questionId": "cabinet-style", "values": ["flat-panel"], "label": "Recommended for Modern" },
          { "questionId": "hardware-style", "values": ["handleless", "bar-pulls"], "label": "Best match" },
          { "questionId": "countertop-material", "values": ["quartz", "concrete", "stainless-steel"], "label": "Popular choice" }
        ]
      }
    },
    {
      "id": "traditional-style-suggestions",
      "description": "Suggest compatible elements for traditional style",
      "condition": {
        "questionId": "kitchen-style",
        "operator": "equals",
        "value": "traditional"
      },
      "action": {
        "type": "highlight-options",
        "targets": [
          { "questionId": "cabinet-style", "values": ["raised-panel", "beadboard"], "label": "Classic choice" },
          { "questionId": "hardware-style", "values": ["knobs", "cup-pulls"], "label": "Traditional match" },
          { "questionId": "countertop-material", "values": ["granite", "marble"], "label": "Elegant pairing" }
        ]
      }
    },
    {
      "id": "farmhouse-style-suggestions",
      "description": "Suggest compatible elements for farmhouse style",
      "condition": {
        "questionId": "kitchen-style",
        "operator": "equals",
        "value": "farmhouse"
      },
      "action": {
        "type": "highlight-options",
        "targets": [
          { "questionId": "cabinet-style", "values": ["shaker", "beadboard"], "label": "Farmhouse favorite" },
          { "questionId": "hardware-style", "values": ["cup-pulls", "knobs"], "label": "Rustic charm" },
          { "questionId": "countertop-material", "values": ["butcher-block", "quartz"], "label": "Country kitchen" }
        ]
      }
    },
    {
      "id": "marble-maintenance-warning",
      "description": "Warn about marble maintenance requirements",
      "condition": {
        "questionId": "countertop-material",
        "operator": "equals",
        "value": "marble"
      },
      "action": {
        "type": "show-message",
        "message": {
          "en": "Marble is beautiful but requires regular sealing and careful maintenance. It can stain and etch from acidic substances.",
          "fr": "Le marbre est magnifique mais nécessite un scellement régulier et un entretien soigneux. Il peut se tacher et s'abîmer au contact de substances acides."
        },
        "severity": "info"
      }
    },
    {
      "id": "butcher-block-maintenance-note",
      "description": "Note about butcher block care",
      "condition": {
        "questionId": "countertop-material",
        "operator": "equals",
        "value": "butcher-block"
      },
      "action": {
        "type": "show-message",
        "message": {
          "en": "Butcher block adds warmth but needs regular oiling and shouldn't be used near water-heavy areas like sinks.",
          "fr": "Le billot de bois ajoute de la chaleur mais nécessite un huilage régulier et ne devrait pas être utilisé près des zones humides comme l'évier."
        },
        "severity": "tip"
      }
    },
    {
      "id": "handleless-tech-suggestion",
      "description": "Suggest smart options for handleless cabinet selection",
      "condition": {
        "questionId": "hardware-style",
        "operator": "equals",
        "value": "handleless"
      },
      "action": {
        "type": "add-tag",
        "tags": ["push-to-open", "servo-drive-compatible", "modern-tech"]
      }
    },
    {
      "id": "color-style-mismatch-warning",
      "description": "Warn if color choice doesn't match style well",
      "condition": {
        "operator": "and",
        "conditions": [
          { "questionId": "kitchen-style", "operator": "equals", "value": "traditional" },
          { "questionId": "color-preference", "operator": "equals", "value": "neutral-dark" }
        ]
      },
      "action": {
        "type": "show-message",
        "message": {
          "en": "Dark moody colors are less common in traditional kitchens but can create a dramatic, sophisticated look if done well.",
          "fr": "Les couleurs sombres sont moins courantes dans les cuisines traditionnelles mais peuvent créer un look dramatique et sophistiqué si bien exécuté."
        },
        "severity": "tip"
      }
    },
    {
      "id": "industrial-material-coherence",
      "description": "Check for industrial style coherence",
      "condition": {
        "questionId": "kitchen-style",
        "operator": "equals",
        "value": "industrial"
      },
      "action": {
        "type": "add-tag",
        "tags": ["exposed-elements", "metal-accents", "raw-materials"]
      }
    }
  ],
  "sectionFlow": {
    "defaultOrder": [
      "kitchen-style",
      "color-preference",
      "cabinet-style",
      "countertop-material",
      "hardware-style",
      "hardware-finish",
      "backsplash-preference",
      "flooring-preference",
      "lighting-style"
    ],
    "adaptiveFlow": true,
    "allowSkip": false,
    "allowBack": true
  },
  "completion": {
    "requiredQuestions": [
      "kitchen-style",
      "color-preference",
      "cabinet-style",
      "countertop-material",
      "hardware-style",
      "hardware-finish",
      "backsplash-preference",
      "flooring-preference",
      "lighting-style"
    ],
    "minimumAnswered": 9,
    "validationMode": "on-section-complete"
  },
  "styleRecommendationRules": {
    "coherenceThreshold": 70,
    "allowMixedStyles": true,
    "maxStyleMix": 2
  }
}
