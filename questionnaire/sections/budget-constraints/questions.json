        {
          "value": "credit-card",
          "label": { "en": "Credit Card", "fr": "Carte de crédit" },
          "description": {
            "en": "For smaller purchases or 0% offers",
            "fr": "Pour petits achats ou offres 0%"
          },
          "tags": ["rewards", "short-term"]
        },
        {
          "value": "contractor-financing",
          "label": {
            "en": "Contractor Financing",
            "fr": "Financement entrepreneur"
