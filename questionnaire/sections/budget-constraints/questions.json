{
  "sectionId": "budget-constraints",
  "version": "1.0.0",
  "metadata": {
    "title": {
      "en": "Budget & Investment",
      "fr": "Budget et investissement"
    },
    "description": {
      "en": "Help us understand your budget to provide the best recommendations",
      "fr": "Aidez-nous à comprendre votre budget pour vous fournir les meilleures recommandations"
    },
    "icon": "dollar-sign",
    "estimatedTime": 4
  },
  "questions": [
    {
      "id": "total-budget",
      "type": "single-choice",
      "required": true,
      "label": {
        "en": "What is your total budget for the kitchen renovation?",
        "fr": "Quel est votre budget total pour la rénovation de cuisine ?"
      },
      "description": {
        "en": "Include all costs: materials, appliances, labor, and contingency",
        "fr": "Incluez tous les coûts : matériaux, appareils, main-d'œuvre et imprévus"
      },
      "options": [
        {
          "value": "under-10k",
          "label": { "en": "Under $10,000", "fr": "Moins de 10 000 €" },
          "description": {
            "en": "Minor updates and refreshes",
            "fr": "Mises à jour et rafraîchissements mineurs"
          },
          "tags": ["budget", "refresh", "cosmetic"]
        },
        {
          "value": "10k-25k",
          "label": { "en": "$10,000 - $25,000", "fr": "10 000 € - 25 000 €" },
          "description": {
            "en": "Moderate renovation with some upgrades",
            "fr": "Rénovation modérée avec quelques améliorations"
          },
          "tags": ["mid-range", "selective-upgrades"]
        },
        {
          "value": "25k-50k",
          "label": { "en": "$25,000 - $50,000", "fr": "25 000 € - 50 000 €" },
          "description": {
            "en": "Substantial renovation with quality materials",
            "fr": "Rénovation substantielle avec matériaux de qualité"
          },
          "tags": ["substantial", "quality"]
        },
        {
          "value": "50k-75k",
          "label": { "en": "$50,000 - $75,000", "fr": "50 000 € - 75 000 €" },
          "description": {
            "en": "Major renovation with premium options",
            "fr": "Rénovation majeure avec options premium"
          },
          "tags": ["major", "premium"]
        },
        {
          "value": "75k-100k",
          "label": { "en": "$75,000 - $100,000", "fr": "75 000 € - 100 000 €" },
          "description": {
            "en": "High-end renovation with top-tier materials",
            "fr": "Rénovation haut de gamme avec matériaux de premier choix"
          },
          "tags": ["high-end", "luxury"]
        },
        {
          "value": "over-100k",
          "label": { "en": "Over $100,000", "fr": "Plus de 100 000 €" },
          "description": {
            "en": "Luxury renovation with no compromises",
            "fr": "Rénovation de luxe sans compromis"
          },
          "tags": ["luxury", "unlimited", "custom"]
        }
      ],
      "scoring": {
        "weight": 5,
        "categories": ["budget-tier"],
        "impactAreas": ["budget"]
      }
    },
    {
      "id": "budget-flexibility",
      "type": "slider",
      "required": true,
      "label": {
        "en": "How flexible is your budget?",
        "fr": "Quelle est la flexibilité de votre budget ?"
      },
      "description": {
        "en": "Can you go over if you find something you love?",
        "fr": "Pouvez-vous dépasser si vous trouvez quelque chose que vous aimez ?"
      },
      "validation": {
        "min": 1,
        "max": 5
      },
      "metadata": {
        "labels": {
          "1": { "en": "Strict limit", "fr": "Limite stricte" },
          "2": { "en": "Slightly flexible", "fr": "Légèrement flexible" },
          "3": { "en": "Moderate flexibility", "fr": "Flexibilité modérée" },
          "4": { "en": "Quite flexible", "fr": "Assez flexible" },
          "5": { "en": "Very flexible", "fr": "Très flexible" }
        }
      },
      "scoring": {
        "weight": 3,
        "categories": ["flexibility"],
        "impactAreas": ["budget"]
      }
    },
    {
      "id": "financing-method",
      "type": "single-choice",
      "required": true,
      "label": {
        "en": "How do you plan to finance your kitchen renovation?",
        "fr": "Comment comptez-vous financer votre rénovation de cuisine ?"
