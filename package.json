{
  "name": "kitchenxpert",
  "version": "1.0.0",
  "private": true,
  "description": "KitchenXpert - Plateforme de conception de cuisines avec IA",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.15.0 <9.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "dev": "turbo run dev --filter=@kitchenxpert/backend --filter=@kitchenxpert/frontend",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "clean:install": "pnpm clean && pnpm install",
    "backend:dev": "pnpm --filter backend dev",
    "frontend:dev": "pnpm --filter frontend dev",
    "3d-engine:dev": "pnpm --filter 3d-engine dev",
    "partner-portal:dev": "pnpm --filter partner-portal dev",
    "ai-modules:setup": "pnpm --filter @kitchenxpert/ai-modules setup:all",
    "ai-modules:setup:unix": "cd packages/ai-modules && python -m venv venv && . venv/bin/activate",
    "docker:dev": "docker-compose -f config/docker/docker-compose.dev.yml up",
    "docker:prod": "docker-compose -f config/docker/docker-compose.prod.yml up",
    "db:migrate": "pnpm --filter backend db:migrate",
    "db:seed": "pnpm --filter backend db:seed",
    "db:reset": "pnpm --filter backend db:reset",
    "catalog:import": "tsx catalog-providers/universal-importer/quick-import.ts",
    "catalog:bulk-import": "tsx catalog-providers/bulk-import/import-all.ts",
    "catalog:generate": "tsx catalog-providers/cli/generate-provider.ts",
    "test:ci": "turbo run test -- --ci --coverage",
    "test:smoke": "pnpm --filter backend test:smoke",
    "migrate:test": "pnpm --filter backend db:migrate:test",
    "migrate:staging": "pnpm --filter backend db:migrate:staging",
    "seed:test": "pnpm --filter backend db:seed:test",
    "start:test": "pnpm --filter backend start:test",
    "test:backend": "pnpm --filter backend test",
    "test:frontend": "pnpm --filter frontend test",
    "test:integration": "pnpm --filter backend test:integration",
    "test:api": "pnpm --filter backend test:api",
    "lint:backend": "pnpm --filter backend lint",
    "lint:frontend": "pnpm --filter frontend lint",
    "type-check:backend": "pnpm --filter backend type-check",
    "type-check:frontend": "pnpm --filter frontend type-check",
    "build:backend": "pnpm --filter backend build",
    "build:frontend": "pnpm --filter frontend build",
    "infisical:dev": "infisical run --env=dev -- turbo run dev --filter=@kitchenxpert/backend --filter=@kitchenxpert/frontend",
    "infisical:backend": "infisical run --env=dev -- pnpm --filter backend dev",
    "infisical:frontend": "infisical run --env=dev -- pnpm --filter frontend dev",
    "infisical:build": "infisical run --env=prod -- turbo run build",
    "infisical:docker:dev": "infisical run --env=dev -- docker-compose -f config/docker/docker-compose.dev.yml up",
    "infisical:docker:prod": "infisical run --env=prod -- docker-compose -f config/docker/docker-compose.prod.yml up"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "csv-parse": "^5.5.3",
    "exceljs": "^4.4.0",
    "tsx": "^4.7.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.19.33",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.8.3",
    "turbo": "^1.12.0",
    "typescript": "^5.3.3"
  },
  "workspaces": [
    "packages/*"
  ],
  "pnpm": {
    "overrides": {
      "axios": "^1.17.0",
      "nodemailer": "^8.0.10",
      "dompurify": "^3.2.4",
      "tar": "^6.2.1",
      "fast-xml-parser": "^5.7.3",
      "undici": "^6.21.0",
      "basic-ftp": "^5.3.1",
      "protobufjs": "^7.6.3",
      "follow-redirects": "^1.16.0"
    }
  }
}
